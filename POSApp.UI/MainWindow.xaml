<Window x:Class="POSApp.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POSApp.UI"
        mc:Ignorable="d"
        Title="Shah Jee Super Store - POS System" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Icon="pack://application:,,,/POSApp.UI;component/app.ico">
    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBar}">
            <Grid>
                <TextBlock Text="Shah Jee Super Store" FontSize="32" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentUserInfo}" FontSize="12" FontWeight="SemiBold" 
                           Foreground="{DynamicResource BrandGoldBrush}" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <!-- Navigation Toolbar -->
        <Border Grid.Row="1" Background="{DynamicResource BrandAccentBrush}" Padding="10">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.15" Direction="270" Color="Black"/>
            </Border.Effect>
            <WrapPanel HorizontalAlignment="Center">
                <!-- Sales -->
                <Button Content="🛒 Sale" Command="{Binding OpenSaleCommand}"
                        Style="{StaticResource NavButtonStyle}" Margin="4"/>
                <Button Content="📦 Whole Sale" Command="{Binding OpenWholeSaleCommand}"
                        Style="{StaticResource NavButtonStyle}" Margin="4"/>
                <Button Content="↩ Sale Return" Command="{Binding OpenSaleReturnCommand}"
                        Style="{StaticResource NavButtonStyle}" Margin="4"/>
                <!-- Inventory -->
                <Button Content="🏷 Products" Command="{Binding OpenProductManagementCommand}"
                        Style="{StaticResource NavButtonStyle}" Margin="4"/>
                <Button Content="📂 Categories" Command="{Binding OpenCategoryManagementCommand}"
                        Style="{StaticResource NavButtonStyle}" Margin="4"/>
                <!-- Reports -->
                <Button Content="📊 Dashboard" Command="{Binding OpenDashboardCommand}"
                        Style="{StaticResource NavButtonStyle}" Margin="4"/>
                <Button Content="📈 Sales Report" Command="{Binding OpenSalesReportCommand}"
                        Style="{StaticResource NavButtonStyle}" Margin="4"/>
                <!-- New Features -->
                <Button Content="💰 Expenses" Command="{Binding OpenExpenseCommand}"
                        Style="{StaticResource NavButtonStyle}" Margin="4"/>
                <Button Content="🏪 Cash Register" Command="{Binding OpenShiftCommand}"
                        Style="{StaticResource NavButtonStyle}" Margin="4"/>
                <Button Content="📒 Khata" Command="{Binding OpenCustomerLedgerCommand}"
                        Style="{StaticResource NavButtonStyle}" Margin="4"/>
                <!-- System -->
                <Button Content="🔄 Sync" Command="{Binding SyncNowCommand}"
                        Style="{StaticResource NeutralButton}" Margin="4"/>
                <Button Content="⇦ Logout" Command="{Binding LogoutCommand}"
                        Style="{StaticResource WarningButton}" Margin="4"/>
                <Button Content="✕ Exit" Command="{Binding ExitCommand}"
                        Style="{StaticResource NeutralButton}" Margin="4"/>
            </WrapPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2" Margin="30">
            <Border Style="{StaticResource ElevatedCardBorder}" Padding="40">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Welcome to POS System" FontSize="36" FontWeight="Bold" 
                               Foreground="{DynamicResource BrandPrimaryBrush}" Margin="0,0,0,20"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Please select an option from the menu above" FontSize="18" 
                               Foreground="#888" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
