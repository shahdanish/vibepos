<Application x:Class="POSApp.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:POSApp.UI"
             xmlns:converters="clr-namespace:POSApp.UI.Converters"
             ThemeMode="System">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Built-in .NET 10 Fluent theme -->
                <ResourceDictionary Source="pack://application:,,,/PresentationFramework.Fluent;component/Themes/Fluent.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ============================================================ -->
            <!--  BRAND COLOR PALETTE                                         -->
            <!-- ============================================================ -->
            <Color x:Key="BrandPrimaryColor">#8B4513</Color>
            <Color x:Key="BrandAccentColor">#D2691E</Color>
            <Color x:Key="BrandGoldColor">#FFD700</Color>
            <Color x:Key="SuccessColor">#4CAF50</Color>
            <Color x:Key="DangerColor">#E53935</Color>
            <Color x:Key="WarningColor">#FF9800</Color>
            <Color x:Key="InfoColor">#2196F3</Color>
            <Color x:Key="PurpleColor">#9C27B0</Color>

            <SolidColorBrush x:Key="BrandPrimaryBrush" Color="#8B4513"/>
            <SolidColorBrush x:Key="BrandAccentBrush" Color="#D2691E"/>
            <SolidColorBrush x:Key="BrandGoldBrush" Color="#FFD700"/>
            <SolidColorBrush x:Key="SuccessBrush" Color="#4CAF50"/>
            <SolidColorBrush x:Key="DangerBrush" Color="#E53935"/>
            <SolidColorBrush x:Key="WarningBrush" Color="#FF9800"/>
            <SolidColorBrush x:Key="InfoBrush" Color="#2196F3"/>
            <SolidColorBrush x:Key="PurpleBrush" Color="#9C27B0"/>
            <SolidColorBrush x:Key="NeutralBrush" Color="#607D8B"/>
            <SolidColorBrush x:Key="RestoreBrush" Color="#8BC34A"/>
            <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F5F5F5"/>
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="White"/>

            <!-- Hover variants (darker) -->
            <SolidColorBrush x:Key="BrandPrimaryHoverBrush" Color="#6B3410"/>
            <SolidColorBrush x:Key="BrandAccentHoverBrush" Color="#A0522D"/>
            <SolidColorBrush x:Key="SuccessHoverBrush" Color="#45a049"/>
            <SolidColorBrush x:Key="DangerHoverBrush" Color="#C62828"/>
            <SolidColorBrush x:Key="WarningHoverBrush" Color="#E68900"/>
            <SolidColorBrush x:Key="InfoHoverBrush" Color="#1976D2"/>
            <SolidColorBrush x:Key="PurpleHoverBrush" Color="#7B1FA2"/>
            <SolidColorBrush x:Key="NeutralHoverBrush" Color="#455A64"/>
            <SolidColorBrush x:Key="RestoreHoverBrush" Color="#689F38"/>

            <!-- ============================================================ -->
            <!--  CARD STYLE — White bg, rounded corners, subtle shadow      -->
            <!-- ============================================================ -->
            <Style x:Key="CardBorder" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="12"/>
                <Setter Property="Margin" Value="0,0,0,10"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.12" Direction="270" Color="Black"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Elevated card for totals/important sections -->
            <Style x:Key="ElevatedCardBorder" TargetType="Border" BasedOn="{StaticResource CardBorder}">
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.18" Direction="270" Color="Black"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================================ -->
            <!--  HEADER BAR STYLE                                            -->
            <!-- ============================================================ -->
            <Style x:Key="HeaderBar" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource BrandPrimaryBrush}"/>
                <Setter Property="Padding" Value="20,15"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.25" Direction="270" Color="Black"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================================ -->
            <!--  BUTTON STYLES — Fluent with brand colors                   -->
            <!-- ============================================================ -->

            <!-- Base accent button template -->
            <ControlTemplate x:Key="AccentButtonTemplate" TargetType="Button">
                <Border x:Name="ButtonBorder"
                        Background="{TemplateBinding Background}"
                        CornerRadius="6"
                        Padding="{TemplateBinding Padding}"
                        SnapsToDevicePixels="True">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.15" Direction="270" Color="Black"/>
                    </Border.Effect>
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                      TextBlock.Foreground="{TemplateBinding Foreground}"
                                      TextBlock.FontWeight="{TemplateBinding FontWeight}"
                                      TextBlock.FontSize="{TemplateBinding FontSize}"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="ButtonBorder" Property="Background" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                        <Setter TargetName="ButtonBorder" Property="Cursor" Value="Hand"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="ButtonBorder" Property="RenderTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                            </Setter.Value>
                        </Setter>
                        <Setter TargetName="ButtonBorder" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <!-- Primary (Brand Brown) -->
            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource BrandPrimaryBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="MinWidth" Value="90"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Tag" Value="{DynamicResource BrandPrimaryHoverBrush}"/>
                <Setter Property="Template" Value="{StaticResource AccentButtonTemplate}"/>
            </Style>

            <!-- Success (Green) -->
            <Style x:Key="SuccessButton" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="MinWidth" Value="90"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Tag" Value="{DynamicResource SuccessHoverBrush}"/>
                <Setter Property="Template" Value="{StaticResource AccentButtonTemplate}"/>
            </Style>

            <!-- Danger (Red) -->
            <Style x:Key="DangerButton" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="MinWidth" Value="90"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Tag" Value="{DynamicResource DangerHoverBrush}"/>
                <Setter Property="Template" Value="{StaticResource AccentButtonTemplate}"/>
            </Style>

            <!-- Warning (Orange) -->
            <Style x:Key="WarningButton" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="MinWidth" Value="90"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Tag" Value="{DynamicResource WarningHoverBrush}"/>
                <Setter Property="Template" Value="{StaticResource AccentButtonTemplate}"/>
            </Style>

            <!-- Info (Blue) -->
            <Style x:Key="InfoButton" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource InfoBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="MinWidth" Value="90"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Tag" Value="{DynamicResource InfoHoverBrush}"/>
                <Setter Property="Template" Value="{StaticResource AccentButtonTemplate}"/>
            </Style>

            <!-- Purple -->
            <Style x:Key="PurpleButton" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource PurpleBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="MinWidth" Value="90"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Tag" Value="{DynamicResource PurpleHoverBrush}"/>
                <Setter Property="Template" Value="{StaticResource AccentButtonTemplate}"/>
            </Style>

            <!-- Neutral (Gray-blue) -->
            <Style x:Key="NeutralButton" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource NeutralBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="MinWidth" Value="90"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Tag" Value="{DynamicResource NeutralHoverBrush}"/>
                <Setter Property="Template" Value="{StaticResource AccentButtonTemplate}"/>
            </Style>

            <!-- Restore (Light Green) -->
            <Style x:Key="RestoreButton" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource RestoreBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="MinWidth" Value="90"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Tag" Value="{DynamicResource RestoreHoverBrush}"/>
                <Setter Property="Template" Value="{StaticResource AccentButtonTemplate}"/>
            </Style>

            <!-- ============================================================ -->
            <!--  NAVIGATION BUTTON STYLE                                     -->
            <!-- ============================================================ -->
            <Style x:Key="NavButtonStyle" TargetType="Button">
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Background" Value="{DynamicResource BrandAccentBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="MinWidth" Value="100"/>
                <Setter Property="Tag" Value="{DynamicResource BrandPrimaryHoverBrush}"/>
                <Setter Property="Template" Value="{StaticResource AccentButtonTemplate}"/>
            </Style>

            <!-- ============================================================ -->
            <!--  SECTION TITLE STYLE                                         -->
            <!-- ============================================================ -->
            <Style x:Key="SectionTitle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{DynamicResource BrandPrimaryBrush}"/>
                <Setter Property="Margin" Value="0,0,0,10"/>
            </Style>

            <!-- ============================================================ -->
            <!--  TOTAL DISPLAY STYLE                                         -->
            <!-- ============================================================ -->
            <Style x:Key="TotalDisplay" TargetType="TextBox">
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Padding" Value="8"/>
                <Setter Property="TextAlignment" Value="Right"/>
                <Setter Property="Background" Value="#FFFACD"/>
                <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
            </Style>

            <!-- ============================================================ -->
            <!--  DATAGRID ENHANCEMENT STYLES                                -->
            <!-- ============================================================ -->
            <Style x:Key="RightAlignStyle" TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="Padding" Value="5"/>
            </Style>

            <Style x:Key="CenterAlignStyle" TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="Padding" Value="5"/>
            </Style>

            <!-- ============================================================ -->
            <!--  CONVERTERS                                                  -->
            <!-- ============================================================ -->
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <converters:IsDeletedToBackgroundConverter x:Key="BoolToBackground"/>
            <converters:IsDeletedToTextConverter x:Key="BoolToText"/>
            <converters:CostPriceEncryptorConverter x:Key="CostPriceEncryptor"/>
            <converters:PurchaseCostEncryptorConverter x:Key="PurchaseCostEncryptor"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
