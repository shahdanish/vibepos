<Window x:Class="POSApp.UI.Views.UserFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:POSApp.UI.Converters"
        Title="{Binding FormTitle}"
        Height="480" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="/app-icon.png">
    <Window.Resources>
        <conv:InverseBooleanConverter x:Key="InvBool"/>
    </Window.Resources>
    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBar}">
            <TextBlock Text="{Binding FormTitle}" FontSize="20" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16">
            <StackPanel>

                <TextBlock Text="Username *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="UsernameBox"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6" Margin="0,0,0,16" FontSize="13"/>

                <TextBlock Text="Role *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding Roles}"
                          SelectedItem="{Binding SelectedRole}"
                          DisplayMemberPath="Name"
                          Padding="8,6" Margin="0,0,0,16" FontSize="13"/>

                <TextBlock FontWeight="SemiBold" Margin="0,0,0,4">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Password *"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                    <Setter Property="Text" Value="New Password (leave blank to keep current)"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <PasswordBox x:Name="PasswordBox"
                             Padding="8,6" Margin="0,0,0,10" FontSize="13"/>

                <TextBlock Text="Confirm Password" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <PasswordBox x:Name="ConfirmPasswordBox"
                             Padding="8,6" Margin="0,0,0,16" FontSize="13"/>

                <TextBlock Text="Status" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="Active"
                                 IsChecked="{Binding IsActive}"
                                 FontSize="13" Margin="0,0,24,0"/>
                    <RadioButton Content="Inactive"
                                 IsChecked="{Binding IsActive, Converter={StaticResource InvBool}}"
                                 FontSize="13"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{DynamicResource BrandAccentBrush}" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="Cancel_Click"
                        Style="{StaticResource NeutralButton}"
                        Padding="16,8" Margin="0,0,8,0"/>
                <Button Content="💾  Save" Click="Save_Click"
                        Style="{StaticResource SuccessButton}"
                        Padding="16,8"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
