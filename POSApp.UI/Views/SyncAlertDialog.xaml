<Window x:Class="POSApp.UI.Views.SyncAlertDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Firebase Sync" SizeToContent="Height" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="36,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Colored header banner -->
        <Border x:Name="TopBanner" Grid.Row="0" Padding="24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Icon circle -->
                <Border Grid.Column="0" Width="52" Height="52" CornerRadius="26"
                        Background="#33FFFFFF" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock x:Name="IconText" Text="✓" FontSize="26" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" Text="Sync Successful"
                               FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="SubtitleText" Text="Firebase database updated"
                               FontSize="12" Foreground="#CCFFFFFF" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body -->
        <Border Grid.Row="1" Background="White" Padding="24,20">
            <StackPanel>
                <!-- Stats cards (success/error mode) -->
                <Grid x:Name="StatsPanel" Visibility="Collapsed" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="8" Padding="16,14">
                        <Border.Background>
                            <SolidColorBrush x:Name="LeftCardBg" Color="#F1F8F1"/>
                        </Border.Background>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="LeftCountText" Text="0"
                                       FontSize="32" FontWeight="Bold" HorizontalAlignment="Center">
                                <TextBlock.Foreground>
                                    <SolidColorBrush x:Name="LeftCountBrush" Color="#4CAF50"/>
                                </TextBlock.Foreground>
                            </TextBlock>
                            <TextBlock x:Name="LeftLabel" Text="Records Synced"
                                       FontSize="11" Foreground="#777"
                                       HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#F5F5F5" CornerRadius="8" Padding="16,14">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="RightValueText" Text="--:--"
                                       FontSize="24" FontWeight="Bold" Foreground="#555"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="RightLabel" Text="Synced At"
                                       FontSize="11" Foreground="#777"
                                       HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Detail message -->
                <TextBlock x:Name="DetailText" TextWrapping="Wrap"
                           FontSize="13" Foreground="#444" LineHeight="22"/>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F7F7F7"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="24,16">
            <Button x:Name="OkBtn" Content="OK" Style="{StaticResource ActionButton}"
                    HorizontalAlignment="Right" Click="OkBtn_Click"/>
        </Border>
    </Grid>
</Window>
