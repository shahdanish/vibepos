<Window x:Class="POSApp.UI.Views.RoleFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding FormTitle}"
        Height="680" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinHeight="500" MinWidth="480"
        Icon="/app-icon.png">
    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBar}">
            <TextBlock Text="{Binding FormTitle}" FontSize="20" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16">
            <StackPanel>

                <!-- Role name and description -->
                <TextBlock Text="Role Name *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding RoleName, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6" Margin="0,0,0,14" FontSize="13"/>

                <TextBlock Text="Description" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding RoleDescription, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6" Margin="0,0,0,20" FontSize="13"
                         Height="54" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>

                <!-- Permissions checklist grouped by category -->
                <TextBlock Text="Permissions" FontSize="15" FontWeight="Bold"
                           Margin="0,0,0,10" Foreground="{DynamicResource BrandPrimaryBrush}"/>

                <ItemsControl ItemsSource="{Binding PermissionCategories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,12" Background="#F5F7FA"
                                    BorderBrush="#DDE3EC" BorderThickness="1"
                                    CornerRadius="6" Padding="12,10">
                                <StackPanel>
                                    <!-- Category header with Select/Deselect all -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Category}"
                                                   FontWeight="Bold" FontSize="13"
                                                   Foreground="#333"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="1"
                                                Content="All"
                                                Command="{Binding DataContext.SelectAllCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource InfoButton}"
                                                Padding="8,3" FontSize="11" Margin="0,0,6,0"/>
                                        <Button Grid.Column="2"
                                                Content="None"
                                                Command="{Binding DataContext.DeselectAllCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource NeutralButton}"
                                                Padding="8,3" FontSize="11"/>
                                    </Grid>

                                    <!-- Permission checkboxes in a WrapPanel -->
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected}"
                                                          Content="{Binding Permission.DisplayName}"
                                                          Margin="0,2,16,4"
                                                          FontSize="12"
                                                          VerticalContentAlignment="Center"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{DynamicResource BrandAccentBrush}" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="Cancel_Click"
                        Style="{StaticResource NeutralButton}"
                        Padding="16,8" Margin="0,0,8,0"/>
                <Button Content="💾  Save Role" Command="{Binding SaveCommand}"
                        Style="{StaticResource SuccessButton}"
                        Padding="16,8"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
