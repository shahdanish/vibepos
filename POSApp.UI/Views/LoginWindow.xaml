<Window x:Class="POSApp.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POSApp.UI.Views"
        mc:Ignorable="d"
        Title="Login - Shah Jee Super Store" 
        Height="500" Width="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    
    <Border Background="#F5F5F5" CornerRadius="15" BorderThickness="2" BorderBrush="#8B4513">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#8B4513" CornerRadius="15,15,0,0" Padding="20">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="🏪 Shah Jee Super Store" FontSize="24" FontWeight="Bold" 
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="POS System Login" FontSize="14" FontWeight="SemiBold" 
                               Foreground="#FFD700" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Login Form -->
            <Grid Grid.Row="1" Margin="30,40,30,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Welcome Message -->
                <TextBlock Grid.Row="0" Text="Welcome Back!" FontSize="28" FontWeight="Bold" 
                           Foreground="#8B4513" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <!-- Username Field -->
                <StackPanel Grid.Row="1" Margin="0,0,0,20">
                    <TextBlock Text="Username" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" Foreground="#333"/>
                    <Border BorderBrush="#8B4513" BorderThickness="1.5" CornerRadius="5">
                        <TextBox x:Name="txtUsername"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                                 FontSize="15" Padding="12,10" 
                                 Background="White" BorderThickness="0"
                                 KeyDown="TxtUsername_KeyDown"/>
                    </Border>
                </StackPanel>

                <!-- Password Field -->
                <StackPanel Grid.Row="2" Margin="0,0,0,20">
                    <TextBlock Text="Password" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" Foreground="#333"/>
                    <Border BorderBrush="#8B4513" BorderThickness="1.5" CornerRadius="5">
                        <PasswordBox x:Name="txtPassword" FontSize="15" Padding="12,10" 
                                     Background="White" BorderThickness="0"
                                     PasswordChanged="TxtPassword_PasswordChanged"
                                     KeyDown="TxtPassword_KeyDown"/>
                    </Border>
                </StackPanel>

                <!-- Error Message -->
                <Border Grid.Row="3" Background="#FFE6E6" BorderBrush="#FF4444" 
                        BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,20"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠️ " FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ErrorMessage}" FontSize="13" 
                                   Foreground="#CC0000" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Buttons -->
                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Content="LOGIN" Command="{Binding LoginCommand}" 
                            Padding="30,12" Margin="0,0,10,0" 
                            Background="#4CAF50" Foreground="White" 
                            FontSize="15" FontWeight="Bold" BorderThickness="0"
                            Cursor="Hand" MinWidth="120">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#45a049"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <Button Content="EXIT" Command="{Binding CancelCommand}" 
                            Padding="30,12" 
                            Background="#f44336" Foreground="White" 
                            FontSize="15" FontWeight="Bold" BorderThickness="0"
                            Cursor="Hand" MinWidth="120">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#da190b"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
