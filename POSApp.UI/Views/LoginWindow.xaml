<Window x:Class="POSApp.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POSApp.UI.Views"
        mc:Ignorable="d"
        Title="Login - Shah Jee Super Store" 
        Height="500" Width="450"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/POSApp.UI;component/app.ico"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    
    <Border Background="{DynamicResource PageBackgroundBrush}" CornerRadius="15" 
            BorderBrush="{DynamicResource BrandPrimaryBrush}" BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="4" BlurRadius="20" Opacity="0.25" Direction="270" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Style="{StaticResource HeaderBar}" CornerRadius="15,15,0,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Shah Jee Super Store" FontSize="24" FontWeight="Bold" 
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="POS System Login" FontSize="14" FontWeight="SemiBold" 
                               Foreground="{DynamicResource BrandGoldBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Login Form -->
            <Grid Grid.Row="1" Margin="30,40,30,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Welcome Message -->
                <TextBlock Grid.Row="0" Text="Welcome Back!" FontSize="28" FontWeight="Bold" 
                           Foreground="{DynamicResource BrandPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <!-- Username Field -->
                <StackPanel Grid.Row="1" Margin="0,0,0,20">
                    <TextBlock Text="Username" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" Foreground="#333"/>
                    <TextBox x:Name="txtUsername"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                             FontSize="15" Padding="12,10" 
                             KeyDown="TxtUsername_KeyDown"/>
                </StackPanel>

                <!-- Password Field -->
                <StackPanel Grid.Row="2" Margin="0,0,0,20">
                    <TextBlock Text="Password" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" Foreground="#333"/>
                    <PasswordBox x:Name="txtPassword" FontSize="15" Padding="12,10" 
                                 PasswordChanged="TxtPassword_PasswordChanged"
                                 KeyDown="TxtPassword_KeyDown"/>
                </StackPanel>

                <!-- Error Message -->
                <Border Grid.Row="3" Background="#FFE6E6" BorderBrush="{DynamicResource DangerBrush}" 
                        BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,20"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠ " FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ErrorMessage}" FontSize="13" 
                                   Foreground="#CC0000" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Buttons -->
                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Content="LOGIN" Command="{Binding LoginCommand}" 
                            Style="{StaticResource SuccessButton}"
                            Padding="30,12" Margin="0,0,10,0" MinWidth="120"
                            FontWeight="Bold" FontSize="15"/>
                    <Button Content="EXIT" Command="{Binding CancelCommand}" 
                            Style="{StaticResource DangerButton}"
                            Padding="30,12" MinWidth="120"
                            FontWeight="Bold" FontSize="15"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
