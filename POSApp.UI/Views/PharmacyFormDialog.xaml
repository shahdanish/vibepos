<Window x:Class="POSApp.UI.Views.PharmacyFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:POSApp.UI.Converters"
        Title="{Binding FormTitle}"
        Height="560" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="/app-icon.png">
    <Window.Resources>
        <conv:InverseBooleanConverter x:Key="InvBool"/>
    </Window.Resources>
    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBar}">
            <TextBlock Text="{Binding FormTitle}" FontSize="20" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16">
            <StackPanel>

                <TextBlock Text="Pharmacy Name *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6" Margin="0,0,0,14" FontSize="13"/>

                <TextBlock Text="Owner Name" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding OwnerName, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6" Margin="0,0,0,14" FontSize="13"/>

                <TextBlock Text="Phone" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6" Margin="0,0,0,14" FontSize="13"/>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="City" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Area / Locality" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Area, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Full Address" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6" Margin="0,0,0,14" FontSize="13"
                         Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="License No" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding LicenseNo, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="NTN" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Ntn, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Status" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="Active"
                                 IsChecked="{Binding IsActive}"
                                 FontSize="13" Margin="0,0,24,0"/>
                    <RadioButton Content="Inactive"
                                 IsChecked="{Binding IsActive, Converter={StaticResource InvBool}}"
                                 FontSize="13"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer buttons -->
        <Border Grid.Row="2" Background="{DynamicResource BrandAccentBrush}" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="Cancel_Click"
                        Style="{StaticResource NeutralButton}"
                        Padding="16,8" Margin="0,0,8,0"/>
                <Button Content="💾  Save" Command="{Binding SaveCommand}"
                        Style="{StaticResource SuccessButton}"
                        Padding="16,8"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
