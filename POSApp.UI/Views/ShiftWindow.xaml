<Window x:Class="POSApp.UI.Views.ShiftWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shift Management - Shah Jee Super Store" Height="650" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBar}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="🏪 Cash Register / Shift" FontSize="24" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding ShiftStatus}" FontSize="12" Foreground="#CBD5E0" 
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Open/Close Shift -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Shift Controls" Style="{StaticResource SectionTitle}"/>

                    <!-- Open Shift Section -->
                    <Border Background="#EBF8FF" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Open New Shift" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                            <TextBlock Text="Opening Cash (Rs.)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding OpeningBalance, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="8" Margin="0,0,0,10"/>
                            <Button Content="🟢 Open Shift" Command="{Binding OpenShiftCommand}" 
                                    Style="{StaticResource SuccessButton}" Padding="10,8"/>
                        </StackPanel>
                    </Border>

                    <!-- Close Shift Section -->
                    <Border Background="#FFF5F5" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Close Current Shift" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                            <TextBlock Text="Count your cash and enter below:" FontSize="12" Margin="0,0,0,10" Foreground="Gray"/>
                            <TextBlock Text="Actual Cash in Drawer (Rs.)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding ClosingBalance, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="8" Margin="0,0,0,10"/>
                            <Button Content="🔴 Close Shift" Command="{Binding CloseShiftCommand}" 
                                    Style="{StaticResource DangerButton}" Padding="10,8"/>
                        </StackPanel>
                    </Border>

                    <Button Content="🔄 Refresh" Command="{Binding RefreshCommand}" 
                            Style="{StaticResource InfoButton}" Padding="10,8" Margin="0,0,0,10"/>
                    <Button Content="Close Window" Click="Close_Click" 
                            Style="{StaticResource NeutralButton}" Padding="10,8"/>
                </StackPanel>
            </Border>

            <!-- Right: Shift History -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Shift History" Style="{StaticResource SectionTitle}"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding ShiftHistory}" 
                              AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Opened" Binding="{Binding OpenedAt, StringFormat=dd/MM hh:mm tt}" Width="120"/>
                            <DataGridTextColumn Header="Closed" Binding="{Binding ClosedAt, StringFormat=dd/MM hh:mm tt}" Width="120"/>
                            <DataGridTextColumn Header="Opening" Binding="{Binding OpeningBalance, StringFormat=N0}" Width="80"/>
                            <DataGridTextColumn Header="Expected" Binding="{Binding ExpectedClosingBalance, StringFormat=N0}" Width="80"/>
                            <DataGridTextColumn Header="Actual" Binding="{Binding ActualClosingBalance, StringFormat=N0}" Width="80"/>
                            <DataGridTextColumn Header="Diff" Binding="{Binding Difference, StringFormat=N0}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
