<Window x:Class="POSApp.UI.Views.DemandOrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Demand Order — Low Stock Items" Height="560" Width="720"
        WindowStartupLocation="CenterScreen" WindowState="Normal">

    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBar}" Padding="20,12">
            <Grid>
                <TextBlock Text="📋 Demand Order" FontSize="22" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <TextBlock FontSize="13" Foreground="#FFD700"
                           HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Run Text="Date: "/>
                    <Run x:Name="TodayDateRun"/>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Items Grid -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="16,12,16,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Edit order quantities, then print the list to purchase these items."
                           FontSize="12" Foreground="Gray" Margin="0,0,0,8"/>
                <DataGrid Grid.Row="1" x:Name="ItemsGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#FFFDF5"
                          CellEditEnding="ItemsGrid_CellEditEnding">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="✓" Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="40"/>
                        <DataGridTextColumn Header="Serial No" Binding="{Binding SerialNo}" IsReadOnly="True" Width="80"
                                            ElementStyle="{StaticResource CenterAlignStyle}"/>
                        <DataGridTextColumn Header="Item" Binding="{Binding ProductName}" IsReadOnly="True" Width="*"/>
                        <DataGridTextColumn Header="Quantity" Width="100"
                                            ElementStyle="{StaticResource CenterAlignStyle}">
                            <DataGridTextColumn.Binding>
                                <Binding Path="OrderQuantity" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged"/>
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Price" Width="120"
                                            ElementStyle="{StaticResource RightAlignStyle}">
                            <DataGridTextColumn.Binding>
                                <Binding Path="CostPrice" Mode="TwoWay" StringFormat="N2" UpdateSourceTrigger="PropertyChanged"/>
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStock}" Value="0">
                                    <Setter Property="Background" Value="#FED7D7"/>
                                    <Setter Property="Foreground" Value="#C53030"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="2" Margin="16,8,16,14">
            <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource BrandPrimaryBrush}">
                <Run Text="Total Bill: Rs. "/>
                <Run x:Name="TotalBillRun"/>
            </TextBlock>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="🖨️ Print Order" Click="Print_Click"
                        Style="{StaticResource PurpleButton}" Padding="14,9" Margin="0,0,10,0"/>
                <Button Content="Close" Click="Close_Click"
                        Style="{StaticResource NeutralButton}" Padding="14,9"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
