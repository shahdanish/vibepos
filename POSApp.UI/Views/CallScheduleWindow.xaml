<Window x:Class="POSApp.UI.Views.CallScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:POSApp.UI.Converters"
        xmlns:prim="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="Call Schedule - Master Pharmaceuticals Distributor"
        Height="720" Width="1180"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Icon="/app-icon.png">
    <Window.Resources>
        <conv:PendingDotVisibilityConverter x:Key="PendingDot"/>
        <conv:DoneTickVisibilityConverter x:Key="DoneTick"/>
    </Window.Resources>

    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBar}" Padding="16,10">
            <Grid>
                <TextBlock Text="🗓 Call Schedule" FontSize="22" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="◀" Command="{Binding PrevPeriodCommand}"
                            Style="{StaticResource NeutralButton}" Padding="10,4" Margin="0,0,6,0" ToolTip="Previous"/>
                    <Button Content="▶" Command="{Binding NextPeriodCommand}"
                            Style="{StaticResource NeutralButton}" Padding="10,4" Margin="0,0,12,0" ToolTip="Next"/>
                    <Button Content="{Binding ViewToggleLabel}" Command="{Binding ToggleViewCommand}"
                            Style="{StaticResource InfoButton}" Padding="12,5" Margin="0,0,6,0"/>
                    <Button Content="🔄 Refresh" Command="{Binding RefreshCommand}"
                            Style="{StaticResource InfoButton}" Padding="12,5" Margin="0,0,6,0"/>
                    <Button Content="✕ Close" Click="Close_Click"
                            Style="{StaticResource NeutralButton}" Padding="12,5"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1" Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: calendar (month) / week strip -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Padding="14" Width="380">
                <StackPanel>
                    <TextBlock Text="Select a date" Style="{StaticResource SectionTitle}"/>

                    <!-- Month view: built-in Calendar with per-day badges -->
                    <Calendar x:Name="MonthCalendar"
                              SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                              DisplayDate="{Binding DisplayMonth, Mode=TwoWay}"
                              HorizontalAlignment="Center"
                              Visibility="{Binding IsMonthView, Converter={StaticResource BoolToVis}}">
                        <Calendar.CalendarDayButtonStyle>
                            <Style TargetType="CalendarDayButton">
                                <Setter Property="ContentTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <Grid Width="26" Height="26">
                                                <TextBlock FontSize="12"
                                                           Text="{Binding DataContext.Day, RelativeSource={RelativeSource AncestorType={x:Type prim:CalendarDayButton}}}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <!-- amber dot = has scheduled calls, some pending -->
                                                <Ellipse Width="6" Height="6" Fill="#F59E0B"
                                                         VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,1">
                                                    <Ellipse.Visibility>
                                                        <MultiBinding Converter="{StaticResource PendingDot}">
                                                            <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType={x:Type prim:CalendarDayButton}}"/>
                                                            <Binding Path="DataContext.DayStatusMap"
                                                                     RelativeSource="{RelativeSource AncestorType=Calendar}"/>
                                                        </MultiBinding>
                                                    </Ellipse.Visibility>
                                                </Ellipse>
                                                <!-- green tick = all calls that day are done -->
                                                <TextBlock Text="✓" Foreground="#16A34A" FontWeight="Bold" FontSize="11"
                                                           VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,1,0">
                                                    <TextBlock.Visibility>
                                                        <MultiBinding Converter="{StaticResource DoneTick}">
                                                            <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType={x:Type prim:CalendarDayButton}}"/>
                                                            <Binding Path="DataContext.DayStatusMap"
                                                                     RelativeSource="{RelativeSource AncestorType=Calendar}"/>
                                                        </MultiBinding>
                                                    </TextBlock.Visibility>
                                                </TextBlock>
                                            </Grid>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Calendar.CalendarDayButtonStyle>
                    </Calendar>

                    <!-- Week view: 7-day strip -->
                    <StackPanel Visibility="{Binding IsWeekView, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding WeekRangeLabel}" FontWeight="SemiBold" FontSize="13"
                                   HorizontalAlignment="Center" Margin="0,4,0,10"/>
                        <ItemsControl ItemsSource="{Binding WeekDays}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1" Columns="7"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding SelectCommand}" Margin="2" Padding="0"
                                            BorderThickness="0" Background="Transparent" Cursor="Hand">
                                        <Border CornerRadius="6" Padding="4,6" BorderThickness="1" BorderBrush="#E0E0E0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="#1565C0"/>
                                                            <Setter Property="BorderBrush" Value="#1565C0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding DayName}" FontSize="10" HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#777"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding DayNumber}" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#222"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <!-- badge -->
                                                <Grid Height="12">
                                                    <Ellipse Width="6" Height="6" Fill="#F59E0B" VerticalAlignment="Center">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="HasPending">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock Text="✓" Foreground="#16A34A" FontWeight="Bold" FontSize="11"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="AllDone">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Legend -->
                    <Border Background="#F8F9FA" CornerRadius="6" Padding="10,8" Margin="0,14,0,0">
                        <StackPanel>
                            <TextBlock Text="Legend" FontWeight="Bold" FontSize="11" Foreground="#555" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <Ellipse Width="8" Height="8" Fill="#F59E0B" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Has scheduled calls (some pending)" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="✓" Foreground="#16A34A" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="All calls done" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Right: selected date entries + add schedule -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Selected date -->
                    <TextBlock Grid.Row="0" Text="{Binding SelectedDateLabel}"
                               FontSize="16" FontWeight="Bold" Foreground="{DynamicResource BrandPrimaryBrush}"
                               Margin="0,0,0,10"/>

                    <!-- Add schedule row -->
                    <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Add a scheduled call" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Doctor -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Doctor *" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" Height="32" VerticalContentAlignment="Center"
                                                  ItemsSource="{Binding Doctors}" SelectedItem="{Binding SelectedDoctor}"
                                                  DisplayMemberPath="DisplayLabel"
                                                  IsEditable="True" IsTextSearchEnabled="True" TextSearch.TextPath="Name"
                                                  Padding="6,0" FontSize="12"/>
                                        <Button Grid.Column="1" Content="＋" Command="{Binding AddDoctorCommand}"
                                                Style="{StaticResource SuccessButton}" Width="32" Height="32" Padding="0"
                                                FontSize="18" FontWeight="Bold" Margin="6,0,0,0" ToolTip="Add a new doctor"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Medical Rep -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Medical Rep *" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" Height="32" VerticalContentAlignment="Center"
                                                  ItemsSource="{Binding MedicalReps}" SelectedItem="{Binding SelectedRep}"
                                                  DisplayMemberPath="DisplayLabel"
                                                  IsEditable="True" IsTextSearchEnabled="True" TextSearch.TextPath="Name"
                                                  Padding="6,0" FontSize="12"/>
                                        <Button Grid.Column="1" Content="＋" Command="{Binding AddMedicalRepCommand}"
                                                Style="{StaticResource SuccessButton}" Width="32" Height="32" Padding="0"
                                                FontSize="18" FontWeight="Bold" Margin="6,0,0,0" ToolTip="Add a new medical rep"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Notes (optional)" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,3"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding NewNotes, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="6" FontSize="12" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="💾 Save Schedule" Command="{Binding SaveScheduleCommand}"
                                        Style="{StaticResource SuccessButton}" Padding="14,7" Margin="10,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Entries grid -->
                    <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
                        <DataGrid ItemsSource="{Binding Entries}" AutoGenerateColumns="False"
                                  CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  AlternatingRowBackground="#F9F9F9" BorderThickness="0"
                                  RowHeight="42" VerticalScrollBarVisibility="Auto">
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="6,0"/>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="S.No" Binding="{Binding Serial}" Width="55"
                                                    ElementStyle="{StaticResource CenterAlignStyle}"/>
                                <DataGridTextColumn Header="Doctor" Binding="{Binding DoctorName}" Width="*"/>
                                <DataGridTextColumn Header="Medical Rep" Binding="{Binding RepName}" Width="*"/>
                                <DataGridTemplateColumn Header="Status" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="11" Padding="12,4" MinWidth="66"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F59E0B"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCallDone}" Value="True">
                                                                <Setter Property="Background" Value="#16A34A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding StatusText}" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Call Done" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Content="✅  Call Done"
                                                        Command="{Binding DataContext.MarkDoneCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SuccessButton}" Padding="12,6" FontSize="11"
                                                        VerticalAlignment="Center"
                                                        IsEnabled="{Binding CanMarkDone}"
                                                        Visibility="{Binding CanMarkDone, Converter={StaticResource BoolToVis}}"/>
                                                <Border CornerRadius="11" Padding="12,4" Background="#E7F6EC"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Visibility="{Binding IsCallDone, Converter={StaticResource BoolToVis}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="✔" Foreground="#16A34A" FontWeight="Bold" FontSize="12"
                                                                   VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                        <TextBlock Text="Done" Foreground="#16A34A" FontWeight="SemiBold" FontSize="11"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="180"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
