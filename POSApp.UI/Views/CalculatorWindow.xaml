<Window x:Class="POSApp.UI.Views.CalculatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calculator" Width="230" Height="310"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        Topmost="True" WindowStartupLocation="Manual"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="CalcBtn" TargetType="Button">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DDEEFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="OpBtn" TargetType="Button" BasedOn="{StaticResource CalcBtn}">
            <Setter Property="Background" Value="#FFE0B2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFCC80"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="EqBtn" TargetType="Button" BasedOn="{StaticResource CalcBtn}">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#388E3C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ClrBtn" TargetType="Button" BasedOn="{StaticResource CalcBtn}">
            <Setter Property="Background" Value="#EF5350"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C62828"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Background="White" Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Display -->
        <Border Grid.Row="0" Background="#263238" CornerRadius="4" Margin="0,0,0,4" Padding="8,4">
            <StackPanel>
                <TextBlock x:Name="ExpressionDisplay" Text="" FontSize="11"
                           Foreground="#90A4AE" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="MainDisplay" Text="0" FontSize="26" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <UniformGrid Grid.Row="1" Rows="5" Columns="4">
            <Button Content="C"  Style="{StaticResource ClrBtn}" Click="Btn_Click" Tag="C"/>
            <Button Content="⌫"  Style="{StaticResource OpBtn}"  Click="Btn_Click" Tag="BS"/>
            <Button Content="%"  Style="{StaticResource OpBtn}"  Click="Btn_Click" Tag="%"/>
            <Button Content="÷"  Style="{StaticResource OpBtn}"  Click="Btn_Click" Tag="/"/>

            <Button Content="7"  Style="{StaticResource CalcBtn}" Click="Btn_Click" Tag="7"/>
            <Button Content="8"  Style="{StaticResource CalcBtn}" Click="Btn_Click" Tag="8"/>
            <Button Content="9"  Style="{StaticResource CalcBtn}" Click="Btn_Click" Tag="9"/>
            <Button Content="×"  Style="{StaticResource OpBtn}"  Click="Btn_Click" Tag="*"/>

            <Button Content="4"  Style="{StaticResource CalcBtn}" Click="Btn_Click" Tag="4"/>
            <Button Content="5"  Style="{StaticResource CalcBtn}" Click="Btn_Click" Tag="5"/>
            <Button Content="6"  Style="{StaticResource CalcBtn}" Click="Btn_Click" Tag="6"/>
            <Button Content="−"  Style="{StaticResource OpBtn}"  Click="Btn_Click" Tag="-"/>

            <Button Content="1"  Style="{StaticResource CalcBtn}" Click="Btn_Click" Tag="1"/>
            <Button Content="2"  Style="{StaticResource CalcBtn}" Click="Btn_Click" Tag="2"/>
            <Button Content="3"  Style="{StaticResource CalcBtn}" Click="Btn_Click" Tag="3"/>
            <Button Content="+"  Style="{StaticResource OpBtn}"  Click="Btn_Click" Tag="+"/>

            <Button Content="+/−" Style="{StaticResource CalcBtn}" Click="Btn_Click" Tag="NEG"/>
            <Button Content="0"  Style="{StaticResource CalcBtn}" Click="Btn_Click" Tag="0"/>
            <Button Content="."  Style="{StaticResource CalcBtn}" Click="Btn_Click" Tag="."/>
            <Button Content="="  Style="{StaticResource EqBtn}"  Click="Btn_Click" Tag="="/>
        </UniformGrid>
    </Grid>
</Window>
