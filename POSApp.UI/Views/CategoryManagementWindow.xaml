<Window x:Class="POSApp.UI.Views.CategoryManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POSApp.UI.Views"
        mc:Ignorable="d"
        Title="Category Management - Shah Jee Super Store" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBar}">
            <TextBlock Text="Category Management" FontSize="24" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Category List -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Categories List" Style="{StaticResource SectionTitle}"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" 
                              AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Category Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="Products" Binding="{Binding Products.Count}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Grid.Row="2" Content="Refresh List" Command="{Binding RefreshCommand}" 
                            Style="{StaticResource InfoButton}" Margin="0,10,0,0" Padding="10,5"/>
                </Grid>
            </Border>

            <!-- Right: Add/Edit Form -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Category Details" Style="{StaticResource SectionTitle}"/>

                    <TextBlock Text="Category Name *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,15"/>

                    <TextBlock Text="Description" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="8" Margin="0,0,0,20" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>

                    <StackPanel>
                        <Button Content="Add New Category" Command="{Binding AddCommand}" 
                                Style="{StaticResource SuccessButton}" Padding="10,8" Margin="0,0,0,10"/>
                        <Button Content="Update Category" Command="{Binding UpdateCommand}" 
                                Style="{StaticResource WarningButton}" Padding="10,8" Margin="0,0,0,10"/>
                        <Button Content="Delete Category" Command="{Binding DeleteCommand}" 
                                Style="{StaticResource DangerButton}" Padding="10,8" Margin="0,0,0,10"/>
                        <Button Content="Clear Form" Command="{Binding ClearCommand}" 
                                Style="{StaticResource NeutralButton}" Padding="10,8" Margin="0,0,0,10"/>
                        <Button Content="Close" Click="Close_Click" 
                                Style="{StaticResource NeutralButton}" Padding="10,8"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
