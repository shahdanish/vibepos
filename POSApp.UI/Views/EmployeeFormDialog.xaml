<Window x:Class="POSApp.UI.Views.EmployeeFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:POSApp.UI.Converters"
        Title="{Binding FormTitle}"
        Height="620" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="/app-icon.png">
    <Window.Resources>
        <conv:InverseBooleanConverter x:Key="InvBool"/>
    </Window.Resources>
    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBar}">
            <TextBlock Text="{Binding FormTitle}" FontSize="20" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16">
            <StackPanel>

                <!-- Employee Code (read-only) -->
                <TextBlock Text="Employee Code" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding EmployeeCode}" IsReadOnly="True"
                         Background="#F5F5F5" Padding="8,6" Margin="0,0,0,14" FontSize="13"/>

                <!-- Name + Father Name -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Employee Name *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Father Name" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FatherName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13"/>
                    </StackPanel>
                </Grid>

                <!-- CNIC + Cell -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CNIC" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Cnic, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13"
                                 ToolTip="Format: 12345-1234567-1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Cell Number" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding CellNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13"/>
                    </StackPanel>
                </Grid>

                <!-- Designation + Department -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Designation *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Designation, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13"
                                 ToolTip="e.g. Pharmacist, Sales Manager, Accountant"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Department" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Department, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13"/>
                    </StackPanel>
                </Grid>

                <!-- Joining Date + Basic Salary -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Joining Date" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <DatePicker SelectedDate="{Binding JoiningDate}"
                                    FontSize="13" Padding="4,4"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Basic Salary (Rs.)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding BasicSalary, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13"/>
                    </StackPanel>
                </Grid>

                <!-- Email -->
                <TextBlock Text="Email" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6" Margin="0,0,0,14" FontSize="13"/>

                <!-- Address -->
                <TextBlock Text="Address" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6" Margin="0,0,0,14" FontSize="13"
                         Height="55" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>

                <!-- Status -->
                <TextBlock Text="Status" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="Active"
                                 IsChecked="{Binding IsActive}"
                                 FontSize="13" Margin="0,0,24,0"/>
                    <RadioButton Content="Inactive"
                                 IsChecked="{Binding IsActive, Converter={StaticResource InvBool}}"
                                 FontSize="13"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{DynamicResource BrandAccentBrush}" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="Cancel_Click"
                        Style="{StaticResource NeutralButton}"
                        Padding="16,8" Margin="0,0,8,0"/>
                <Button Content="💾  Save" Command="{Binding SaveCommand}"
                        Style="{StaticResource SuccessButton}"
                        Padding="16,8"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
