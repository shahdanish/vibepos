<Window x:Class="POSApp.UI.Views.ProductManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POSApp.UI.Views"
        mc:Ignorable="d"
        Title="Product Management - Shah Jee Super Store" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#8B4513" Padding="15">
            <TextBlock Text="Product Management" FontSize="24" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Product List -->
            <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="1" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Products List" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" 
                              AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product ID" Binding="{Binding ProductId}" Width="100"/>
                            <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="120"/>
                            <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category.Name}" Width="100"/>
                            <DataGridTextColumn Header="Cost" Binding="{Binding CostPrice, StringFormat=N2}" Width="70"/>
                            <DataGridTextColumn Header="Retail" Binding="{Binding UnitPrice, StringFormat=N2}" Width="70"/>
                            <DataGridTextColumn Header="W/Sale" Binding="{Binding WholesalePrice, StringFormat=N2}" Width="70"/>
                            <DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="60"/>
                            <DataGridTextColumn Header="Rack" Binding="{Binding Rack}" Width="60"/>
                            <DataGridTemplateColumn Header="Status" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding IsDeleted, Converter={StaticResource BoolToBackground}}" 
                                                CornerRadius="3" Padding="5,2" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding IsDeleted, Converter={StaticResource BoolToText}}" 
                                                       FontSize="10" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                        <CheckBox Content="Show Deleted" IsChecked="{Binding ShowDeletedProducts}" 
                                  FontSize="13" FontWeight="SemiBold" Foreground="#FF5722"
                                  ToolTip="Toggle to show/hide deleted products" Margin="0,0,10,0"/>
                        <Button Content="🔄 Refresh List" Command="{Binding RefreshCommand}" 
                                Padding="10,5" Background="#2196F3" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right: Add/Edit Form -->
            <Border Grid.Column="2" BorderBrush="#DDD" BorderThickness="1" Padding="15">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Product Details" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                        <TextBlock Text="Product ID" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding ProductId, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,10,0"/>
                            <Button Grid.Column="1" Content="🔄 Auto" Command="{Binding GenerateIdCommand}" 
                                    Padding="10,8" Background="#2196F3" Foreground="White" ToolTip="Auto-generate 5-digit ID"/>
                        </Grid>

                        <TextBlock Text="Barcode" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,10"/>

                        <TextBlock Text="Product Name *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,10"/>

                        <TextBlock Text="Category" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" 
                                  DisplayMemberPath="Name" Padding="8" Margin="0,0,0,10"/>

                        <TextBlock Text="Cost Price (Rs)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding CostPrice, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,10"/>

                        <TextBlock Text="Retail Price (Rs)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,10"/>

                        <TextBlock Text="Wholesale Price (Rs)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding WholesalePrice, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,10"/>

                        <TextBlock Text="Stock Quantity" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Stock, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,10"/>

                        <TextBlock Text="Rack/Location" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Rack, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,15"/>

                        <StackPanel>
                            <Button Content="Add New Product" Command="{Binding AddCommand}" 
                                    Padding="10,8" Margin="0,0,0,10" Background="#4CAF50" Foreground="White"/>
                            <Button Content="Update Product" Command="{Binding UpdateCommand}" 
                                    Padding="10,8" Margin="0,0,0,10" Background="#FF9800" Foreground="White"/>
                            <Button Content="Delete Product" Command="{Binding DeleteCommand}" 
                                    Padding="10,8" Margin="0,0,0,10" Background="#f44336" Foreground="White"/>
                            <Button Content="♻️ Restore Product" Command="{Binding RestoreCommand}" 
                                    Padding="10,8" Margin="0,0,0,10" Background="#8BC34A" Foreground="White"
                                    Visibility="{Binding SelectedProduct.IsDeleted, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"/>
                            <Button Content="Clear Form" Command="{Binding ClearCommand}" 
                                    Padding="10,8" Margin="0,0,0,10" Background="#9E9E9E" Foreground="White"/>
                            <Button Content="Close" Click="Close_Click" 
                                    Padding="10,8" Background="#607D8B" Foreground="White"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
