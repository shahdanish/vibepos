<Window x:Class="POSApp.UI.Views.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Print Preview" 
        Height="700" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Preview Content -->
        <Border Grid.Row="0" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="3" Padding="10">
            <FlowDocumentScrollViewer x:Name="DocViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
        </Border>
        
        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="🖨️ Print" Click="Print_Click" 
                    Padding="20,8" Margin="0,0,10,0" 
                    Background="#9C27B0" Foreground="White"
                    FontSize="13" FontWeight="Bold" MinWidth="100" BorderThickness="0"/>
            <Button Content="Cancel" Click="Cancel_Click" 
                    Padding="20,8" 
                    Background="#9E9E9E" Foreground="White"
                    FontSize="13" FontWeight="Bold" MinWidth="100" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
