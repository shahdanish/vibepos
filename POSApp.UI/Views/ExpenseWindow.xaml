<Window x:Class="POSApp.UI.Views.ExpenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Expense Tracking - Shah Jee Super Store" Height="650" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBar}">
            <TextBlock Text="💰 Daily Expenses" FontSize="24" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Expense List -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Expenses" Style="{StaticResource SectionTitle}"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Date:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <DatePicker SelectedDate="{Binding FilterDate}" Width="200"/>
                    </StackPanel>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding Expenses}" 
                              AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Date, StringFormat=hh:mm tt}" Width="80"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=N2}" Width="100"/>
                            <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="120"/>
                            <DataGridTemplateColumn Header="" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="❌" Command="{Binding DataContext.DeleteExpenseCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                CommandParameter="{Binding}" Style="{StaticResource DangerButton}" Padding="4,2" FontSize="10"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="3" Background="#2D3748" CornerRadius="8" Padding="15" Margin="0,10,0,0">
                        <TextBlock Foreground="White" FontSize="18" FontWeight="Bold">
                            <Run Text="Total Expenses: Rs."/>
                            <Run Text="{Binding TotalExpenses, StringFormat=N2}"/>
                        </TextBlock>
                    </Border>
                </Grid>
            </Border>

            <!-- Right: Add Expense Form -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Add Expense" Style="{StaticResource SectionTitle}"/>

                    <TextBlock Text="Description *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,15"/>

                    <TextBlock Text="Amount (Rs.) *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,15"/>

                    <TextBlock Text="Note (Optional)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="8" Margin="0,0,0,20" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

                    <Button Content="➕ Add Expense" Command="{Binding AddExpenseCommand}" 
                            Style="{StaticResource SuccessButton}" Padding="10,8" Margin="0,0,0,10"/>
                    <Button Content="🔄 Refresh" Command="{Binding RefreshCommand}" 
                            Style="{StaticResource InfoButton}" Padding="10,8" Margin="0,0,0,10"/>
                    <Button Content="Close" Click="Close_Click" 
                            Style="{StaticResource NeutralButton}" Padding="10,8"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
