<Window x:Class="POSApp.UI.Views.ExpenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Expense Tracking - Shah Jee Super Store" Height="850" Width="1400"
        WindowStartupLocation="CenterScreen" WindowState="Maximized">

    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBar}" Padding="20">
            <Grid>
                <TextBlock Text="Expense Tracking &amp; Analytics" FontSize="28" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <Button Content="Close" Click="Close_Click" HorizontalAlignment="Right"
                        Style="{StaticResource PrimaryButton}" Padding="15,8"/>
            </Grid>
        </Border>

        <!-- Quick Period Buttons -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="10,10,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Quick Filters" Style="{StaticResource SectionTitle}" Margin="0,0,0,15"/>

                <WrapPanel Grid.Row="1">
                    <Button Content="DAILY" Command="{Binding SetDailyCommand}"
                            Style="{StaticResource SuccessButton}" Padding="20,12" Margin="0,0,10,10" MinWidth="130"
                            FontSize="14" FontWeight="Bold"/>
                    <Button Content="WEEKLY" Command="{Binding SetWeeklyCommand}"
                            Style="{StaticResource InfoButton}" Padding="20,12" Margin="0,0,10,10" MinWidth="130"
                            FontSize="14" FontWeight="Bold"/>
                    <Button Content="MONTHLY" Command="{Binding SetMonthlyCommand}"
                            Style="{StaticResource WarningButton}" Padding="20,12" Margin="0,0,10,10" MinWidth="130"
                            FontSize="14" FontWeight="Bold"/>
                    <Button Content="YEARLY" Command="{Binding SetYearlyCommand}"
                            Style="{StaticResource PurpleButton}" Padding="20,12" Margin="0,0,10,10" MinWidth="130"
                            FontSize="14" FontWeight="Bold"/>
                    <Button Content="CUSTOM RANGE" Command="{Binding SetCustomCommand}"
                            Style="{StaticResource NeutralButton}" Padding="20,12" Margin="0,0,10,10" MinWidth="150"
                            FontSize="14" FontWeight="Bold"/>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Expense List -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding PeriodDescription}" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource BrandPrimaryBrush}" Margin="0,0,0,10"/>

                    <!-- Navigator / Custom Range -->
                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <!-- Navigation arrows (non-custom) -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Visibility="{Binding ShowDateNavigator, Converter={StaticResource BoolToVis}}">
                            <Button Content="◀" Command="{Binding PreviousPeriodCommand}"
                                    Width="34" Height="30" FontSize="14" Padding="0"
                                    Style="{StaticResource NeutralButton}" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding PeriodDescription}" FontSize="14" FontWeight="SemiBold"
                                       VerticalAlignment="Center" MinWidth="240" TextAlignment="Center"/>
                            <Button Content="▶" Command="{Binding NextPeriodCommand}"
                                    Width="34" Height="30" FontSize="14" Padding="0"
                                    Style="{StaticResource NeutralButton}" Margin="10,0,0,0"/>
                        </StackPanel>

                        <!-- Custom date range pickers -->
                        <Border Visibility="{Binding IsCustomPeriod, Converter={StaticResource BoolToVis}}"
                                Style="{StaticResource CardBorder}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="From:" FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <DatePicker Grid.Column="1" SelectedDate="{Binding CustomStartDate}"
                                            FontSize="14" Padding="8" Margin="0,0,15,0"/>
                                <TextBlock Grid.Column="2" Text="To:" FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <DatePicker Grid.Column="3" SelectedDate="{Binding CustomEndDate}"
                                            FontSize="14" Padding="8"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="2" ItemsSource="{Binding Expenses}"
                              AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                              AlternatingRowBackground="#F9F9F9" HeadersVisibility="All"
                              GridLinesVisibility="Horizontal" BorderThickness="1" BorderBrush="#DDD">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date / Time" Binding="{Binding Date, StringFormat=dd/MM/yyyy hh:mm tt}" Width="160"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" MinWidth="150"/>
                            <DataGridTextColumn Header="Amount (Rs.)" Binding="{Binding Amount, StringFormat=N2}" Width="130"
                                                ElementStyle="{StaticResource RightAlignStyle}"/>
                            <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="160"/>
                            <DataGridTemplateColumn Header="Action" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Delete"
                                                Command="{Binding DataContext.DeleteExpenseCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource DangerButton}" Padding="6,4" FontSize="11"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Right Panel: Summary + Add Form -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Summary -->
                        <TextBlock Text="Summary" Style="{StaticResource SectionTitle}" Margin="0,0,0,15"/>

                        <Border Background="#FCE4EC" Padding="15" Margin="0,0,0,15" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="Total Expenses" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding TotalExpenses, StringFormat=Rs. {0:N2}}" FontSize="24" FontWeight="Bold" Foreground="#E91E63"/>
                            </StackPanel>
                        </Border>

                        <!-- Add Expense Form -->
                        <Border BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="0,15,0,0" Margin="0,5,0,0">
                            <StackPanel>
                                <TextBlock Text="Add Expense" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource BrandPrimaryBrush}" Margin="0,0,0,15"/>

                                <TextBlock Text="Description *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="8" FontSize="13" Margin="0,0,0,12"/>

                                <TextBlock Text="Amount (Rs.) *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="8" FontSize="13" TextAlignment="Right" Margin="0,0,0,12"/>

                                <TextBlock Text="Note (Optional)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="8" FontSize="13" Margin="0,0,0,20" Height="65"
                                         TextWrapping="Wrap" AcceptsReturn="True"/>

                                <Button Content="Add Expense" Command="{Binding AddExpenseCommand}"
                                        Style="{StaticResource SuccessButton}" Padding="12,10" FontSize="14"
                                        FontWeight="Bold" Margin="0,0,0,8"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Footer Actions -->
        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Margin="10,0,10,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Print Report" Command="{Binding PrintReportCommand}"
                        Style="{StaticResource InfoButton}" Padding="20,10" Margin="0,0,10,0" MinWidth="150"
                        FontSize="14" FontWeight="Bold"/>
                <Button Content="Refresh" Command="{Binding RefreshCommand}"
                        Style="{StaticResource WarningButton}" Padding="20,10" MinWidth="120"
                        FontSize="14" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
