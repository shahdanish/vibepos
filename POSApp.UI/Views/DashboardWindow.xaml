<Window x:Class="POSApp.UI.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:POSApp.UI.Views"
        Title="Dashboard - Shah Jee Super Store" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen" WindowState="Maximized">
    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBar}">
            <TextBlock Text="📊 Today's Dashboard" FontSize="24" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Dashboard content -->
        <views:DashboardView Grid.Row="1" DataContext="{Binding}"/>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="20,8,20,12">
            <Button Content="Close" Click="Close_Click"
                    Style="{StaticResource NeutralButton}" Padding="14,8"/>
        </StackPanel>
    </Grid>
</Window>
