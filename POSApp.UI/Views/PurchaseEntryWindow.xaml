<Window x:Class="POSApp.UI.Views.PurchaseEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Purchase / Stock Entry" Height="650" Width="1000"
        WindowStartupLocation="CenterOwner" Icon="/app-icon.png">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Purchase / Stock Entry" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Purchase #:" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,5,5"/>
                <TextBlock Grid.Column="1" Text="{Binding PurchaseNumber}" FontWeight="Bold" Margin="0,0,5,5"/>
                <TextBlock Text="Date:" Grid.Column="2" VerticalAlignment="Center" Margin="10,0,5,5"/>
                <DatePicker Grid.Column="3" SelectedDate="{Binding PurchaseDate}" Margin="0,0,5,5"/>
                <TextBlock Text="Supplier:" Grid.Column="4" VerticalAlignment="Center" Margin="10,0,5,5"/>
                <ComboBox Grid.Column="5" ItemsSource="{Binding Suppliers}" DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding SelectedSupplierId}" Margin="0,0,5,5"/>
            </Grid>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Add Items" Padding="10" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Search Product:" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                    <ListBox ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" Height="200" Margin="0,0,0,10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding ProductName}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding ProductId}" FontSize="10" Foreground="Gray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,5,0">
                            <TextBlock Text="Quantity:" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding Quantity}" Padding="5"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Text="Unit Cost:" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding UnitCost}" Padding="5"/>
                        </StackPanel>
                    </Grid>
                    <Button Content="Add Item" Command="{Binding AddItemCommand}" Margin="0,10,0,0" Padding="10,5" Background="#2196F3" Foreground="White"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="Purchase Items" Padding="10" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListView ItemsSource="{Binding Items}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Product" DisplayMemberBinding="{Binding ProductName}" Width="200"/>
                                <GridViewColumn Header="Qty" DisplayMemberBinding="{Binding Quantity}" Width="80"/>
                                <GridViewColumn Header="Cost" DisplayMemberBinding="{Binding UnitCost, StringFormat={}{0:N2}}" Width="100"/>
                                <GridViewColumn Header="Total" DisplayMemberBinding="{Binding Total, StringFormat={}{0:N2}}" Width="100"/>
                                <GridViewColumn Header="Action" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Remove" Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Padding="5,2" FontSize="10"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <StackPanel Grid.Row="1" Margin="0,10,0,0">
                        <TextBlock Text="{Binding TotalAmount, StringFormat='Total: {0:N2}'}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Save Purchase" Command="{Binding SaveCommand}" Padding="20,8" FontSize="14" Background="#4CAF50" Foreground="White"/>
            <Button Content="New" Command="{Binding NewCommand}" Padding="20,8" Margin="10,0,0,0" FontSize="14"/>
            <Button Content="Close" Click="CloseButton_Click" Padding="20,8" Margin="10,0,0,0" FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>
