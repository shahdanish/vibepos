<Window x:Class="POSApp.UI.Views.PurchaseEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Purchase Management - Shah Jee Super Store" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen" WindowState="Maximized">
    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource SuccessBrush}" Padding="15">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.25" Direction="270" Color="Black"/>
            </Border.Effect>
            <Grid>
                <TextBlock Text="PURCHASE MANAGEMENT" FontSize="28" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding PurchaseNumber, StringFormat='Purchase #: {0}'}"
                           FontSize="18" FontWeight="Bold" Foreground="Yellow"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Purchase Info -->
            <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Purchase Date" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                        <DatePicker SelectedDate="{Binding PurchaseDate}" FontSize="13" Padding="6"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0">
                        <TextBlock Text="Supplier (Optional)" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                        <ComboBox ItemsSource="{Binding Suppliers}" DisplayMemberPath="Name"
                                  SelectedValuePath="Id" SelectedValue="{Binding SelectedSupplierId}"
                                  FontSize="13" Padding="6"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="10,0,0,0">
                        <TextBlock Text="Notes (Optional)" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" Padding="6"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main: Form + Items -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Product Form -->
                <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,10,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Mode Toggle -->
                            <Border Background="#F0F4F8" CornerRadius="6" Padding="8" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Add Product Mode" FontWeight="Bold" FontSize="11"
                                               Foreground="#555" Margin="0,0,0,6"/>
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton Content="Existing Product"
                                                     IsChecked="{Binding IsExistingProductMode, Mode=TwoWay}"
                                                     FontSize="12" FontWeight="SemiBold" Margin="0,0,20,0"/>
                                        <RadioButton Content="New Product"
                                                     IsChecked="{Binding IsNewProductMode, Mode=TwoWay}"
                                                     FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ===== EXISTING PRODUCT PANEL ===== -->
                            <StackPanel Visibility="{Binding IsExistingProductMode, Converter={StaticResource BoolToVis}}">

                                <TextBlock Text="Select Product" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                                <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}"
                                          DisplayMemberPath="ProductName" IsEditable="True" IsTextSearchEnabled="True"
                                          FontSize="13" Padding="6" Margin="0,0,0,8"/>

                                <!-- Stock info -->
                                <Border Background="#E8F5E9" CornerRadius="4" Padding="8" Margin="0,0,0,10"
                                        Visibility="{Binding SelectedProduct, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CurrentStockInfo}" FontSize="12"
                                                   Foreground="{DynamicResource SuccessBrush}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding AvgCostPreview}" FontSize="11"
                                                   Foreground="{DynamicResource InfoBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                        <TextBlock Text="New Cost Price (Rs)" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                                        <TextBox Text="{Binding UnitCost, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="13" Padding="6" TextAlignment="Right"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                        <TextBlock Text="Quantity" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                                        <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="13" Padding="6" TextAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <Button Content="ADD ITEM" Command="{Binding AddExistingItemCommand}"
                                        Style="{StaticResource SuccessButton}" Padding="12,10" HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <!-- ===== NEW PRODUCT PANEL ===== -->
                            <StackPanel Visibility="{Binding IsNewProductMode, Converter={StaticResource BoolToVis}}">

                                <TextBlock Text="Product Name" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                                <TextBox Text="{Binding NewProductName, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="13" Padding="6" Margin="0,0,0,8"/>

                                <!-- Barcode row -->
                                <TextBlock Text="Barcode" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding NewBarcode, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="13" Padding="6" Margin="0,0,5,0"/>
                                    <Button Grid.Column="1" Content="AUTO" Command="{Binding GenerateBarcodeCommand}"
                                            Style="{StaticResource InfoButton}" Padding="10,6" FontSize="11"/>
                                </Grid>

                                <TextBlock Text="Category (Optional)" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                                <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}"
                                          DisplayMemberPath="Name" FontSize="13" Padding="6" Margin="0,0,0,8"/>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                        <TextBlock Text="Cost Price (Rs)" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                                        <TextBox Text="{Binding NewCostPrice, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="13" Padding="6" TextAlignment="Right"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                        <TextBlock Text="Sale Price (Rs)" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                                        <TextBox Text="{Binding NewUnitPrice, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="13" Padding="6" TextAlignment="Right"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                        <TextBlock Text="Wholesale Price (Rs)" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                                        <TextBox Text="{Binding NewWholesalePrice, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="13" Padding="6" TextAlignment="Right"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                        <TextBlock Text="Quantity" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                                        <TextBox Text="{Binding NewQuantity, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="13" Padding="6" TextAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                        <TextBlock Text="Min Stock Alert" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                                        <TextBox Text="{Binding NewMinStock, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="13" Padding="6" TextAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                        <TextBlock Text="Rack/Location" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                                        <TextBox Text="{Binding NewRack, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="13" Padding="6"/>
                                    </StackPanel>
                                </Grid>

                                <Button Content="ADD &amp; CREATE PRODUCT" Command="{Binding AddNewProductItemCommand}"
                                        Style="{StaticResource InfoButton}" Padding="12,10" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Right: Items Grid -->
                <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Purchase Items" Style="{StaticResource SectionTitle}"/>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding Items}" AutoGenerateColumns="False"
                                  CanUserAddRows="False" AlternatingRowBackground="#F9F9F9"
                                  HeadersVisibility="All" GridLinesVisibility="Horizontal" BorderThickness="0"
                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Type" Binding="{Binding TypeBadge}" Width="75" IsReadOnly="True"
                                                    ElementStyle="{StaticResource CenterAlignStyle}"/>
                                <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="60"
                                                    ElementStyle="{StaticResource CenterAlignStyle}"/>
                                <DataGridTextColumn Header="Unit Cost" Binding="{Binding UnitCost, StringFormat=N2}" Width="90"
                                                    ElementStyle="{StaticResource RightAlignStyle}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Avg Cost After" Binding="{Binding AvgCostAfter, StringFormat=N2}" Width="110"
                                                    ElementStyle="{StaticResource RightAlignStyle}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=N2}" Width="100"
                                                    ElementStyle="{StaticResource RightAlignStyle}" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="Action" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Del"
                                                    Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DangerButton}" Padding="6,2" FontSize="11"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="2" Background="#E8F5E9" Padding="12,10" Margin="0,8,0,0" CornerRadius="6">
                            <Grid>
                                <TextBlock Text="TOTAL PURCHASE:" FontSize="14" FontWeight="Bold"
                                           Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TotalAmount, StringFormat='Rs. {0:N2}'}"
                                           FontSize="20" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Action Buttons -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0,10,0,0">
                <WrapPanel HorizontalAlignment="Left">
                    <Button Content="SAVE PURCHASE" Command="{Binding SaveCommand}"
                            Style="{StaticResource SuccessButton}" Padding="18,10" Margin="0,0,8,0" MinWidth="150"/>
                    <Button Content="NEW" Command="{Binding NewCommand}"
                            Style="{StaticResource InfoButton}" Padding="18,10" Margin="0,0,8,0" MinWidth="100"/>
                    <Button Content="CLOSE" Click="CloseButton_Click"
                            Style="{StaticResource NeutralButton}" Padding="18,10" MinWidth="100"/>
                </WrapPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
