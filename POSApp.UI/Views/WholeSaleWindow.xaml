<Window x:Class="POSApp.UI.Views.WholeSaleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POSApp.UI.Views"
        mc:Ignorable="d"
        Title="Whole Sale - Shah Jee Super Store" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen" WindowState="Maximized">
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#8B4513" Padding="15">
            <Grid>
                <TextBlock Text="WHOLE SALE" FontSize="28" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding InvoiceNumber, StringFormat='Invoice #: {0}'}" 
                           FontSize="18" FontWeight="Bold" Foreground="Yellow" 
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Main Content Grid -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Top Inputs -->
                <RowDefinition Height="*"/>    <!-- Sale Items Grid (Stretches) -->
                <RowDefinition Height="Auto"/> <!-- Bottom Actions/Totals -->
            </Grid.RowDefinitions>

            <!-- Top Sections (Wrapped in ScrollViewer for small screens) -->
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" MaxHeight="250" Margin="0,0,0,10">
                <StackPanel>
                    <!-- Top: Customer & Payment Info -->
                    <Border Background="White" Padding="12" Margin="0,0,0,10" CornerRadius="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Customer Name" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                                <TextBox Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="13" Padding="6"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="10,0">
                                <TextBlock Text="Payment Method" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                                <ComboBox SelectedItem="{Binding PaymentType}" FontSize="13" Padding="6">
                                    <ComboBoxItem Content="Cash" IsSelected="True"/>
                                    <ComboBoxItem Content="Credit Card"/>
                                    <ComboBoxItem Content="Bank Transfer"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                <TextBlock Text="Sale Date" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                                <DatePicker SelectedDate="{Binding SaleDate}" FontSize="13" Padding="6"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Product Entry Section -->
                    <Border Background="White" Padding="12" Margin="0,0,0,5" CornerRadius="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Product (Scan Barcode or Select)" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                                <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" 
                                          DisplayMemberPath="ProductName" IsEditable="True" 
                                          Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}"
                                          FontSize="13" Padding="6"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="Price (Rs)" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                                <TextBox Text="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="13" Padding="6" TextAlignment="Right"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                <TextBlock Text="Qty" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                                <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="13" Padding="6" TextAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="0,0,10,0">
                                <TextBlock Text="Disc %" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                                <TextBox Text="{Binding DiscountPercent, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="13" Padding="6" TextAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4" Margin="0,0,10,0">
                                <TextBlock Text="Stock" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                                <TextBox Text="{Binding SelectedProduct.Stock}" FontSize="13" Padding="6" 
                                         IsReadOnly="True" Background="#f0f0f0" TextAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="5" VerticalAlignment="Bottom">
                                <Button Content="Add Item" Command="{Binding AddItemCommand}" 
                                        Padding="15,8" Background="#4CAF50" Foreground="White" 
                                        FontSize="13" FontWeight="Bold" BorderThickness="0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Items Grid (Row 1 - Stretches) -->
            <Border Grid.Row="1" Background="White" Padding="12" Margin="0,0,0,10" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Sale Items" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding SaleItems}" AutoGenerateColumns="False" 
                              CanUserAddRows="False" AlternatingRowBackground="#F9F9F9" 
                              HeadersVisibility="All" GridLinesVisibility="Horizontal" BorderThickness="0"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product ID" Binding="{Binding ProductId}" Width="120"/>
                            <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat=N2}" Width="100" ElementStyle="{StaticResource RightAlignStyle}"/>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="70" ElementStyle="{StaticResource CenterAlignStyle}"/>
                            <DataGridTextColumn Header="Disc %" Binding="{Binding DiscountPercent}" Width="70" ElementStyle="{StaticResource CenterAlignStyle}"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=N2}" Width="110" ElementStyle="{StaticResource RightAlignStyle}"/>
                            <DataGridTemplateColumn Header="Action" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Del" Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                CommandParameter="{Binding}" Padding="6,2" Background="#f44336" 
                                                Foreground="White" BorderThickness="0" FontSize="11"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Bottom: Totals & Actions (Row 2) -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="350"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Action Buttons -->
                <Border Grid.Column="0" Background="White" Padding="12" Margin="0,0,10,0" CornerRadius="5">
                    <WrapPanel VerticalAlignment="Bottom" HorizontalAlignment="Left">
                        <Button Content="NEW SALE" Command="{Binding NewCommand}" 
                                Padding="15,10" Margin="0,0,8,5" Background="#2196F3" Foreground="White" 
                                FontSize="13" FontWeight="Bold" MinWidth="110" BorderThickness="0"/>
                        <Button Content="SAVE SALE" Command="{Binding SaveCommand}" 
                                Padding="15,10" Margin="0,0,8,5" Background="#4CAF50" Foreground="White" 
                                FontSize="13" FontWeight="Bold" MinWidth="110" BorderThickness="0"/>
                        <Button Content="PRINT" Command="{Binding PrintCommand}" 
                                Padding="15,10" Margin="0,0,8,5" Background="#9C27B0" Foreground="White" 
                                FontSize="13" FontWeight="Bold" MinWidth="110" BorderThickness="0"/>
                        <Button Content="CANCEL" Command="{Binding CancelCommand}" 
                                Padding="15,10" Margin="0,0,8,5" Background="#FF9800" Foreground="White" 
                                FontSize="13" FontWeight="Bold" MinWidth="110" BorderThickness="0"/>
                        <Button Content="CLOSE" Click="Exit_Click" 
                                Padding="15,10" Margin="0,0,0,5" Background="#9E9E9E" Foreground="White" 
                                FontSize="13" FontWeight="Bold" MinWidth="110" BorderThickness="0"/>
                    </WrapPanel>
                </Border>

                <!-- Right: Totals -->
                <Border Grid.Column="1" Background="White" Padding="15" CornerRadius="5">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Discount Products:" FontSize="13" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding DiscountOnProducts, UpdateSourceTrigger=PropertyChanged}" 
                                     FontSize="13" Padding="6" Width="120" HorizontalAlignment="Right" TextAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Discount Bill:" FontSize="13" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding DiscountOnBill, UpdateSourceTrigger=PropertyChanged}" 
                                     FontSize="13" Padding="6" Width="120" HorizontalAlignment="Right" TextAlignment="Right"/>
                        </Grid>

                        <Border BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="0,8,0,0"/>

                        <Grid Margin="0,8,0,8">
                            <TextBlock Text="TOTAL BILL:" FontSize="16" FontWeight="Bold" Foreground="#f44336"/>
                            <TextBox Text="{Binding TotalBill, StringFormat=Rs. {0:N2}, Mode=OneWay}" 
                                     FontSize="18" FontWeight="Bold" Padding="8" Width="180" 
                                     HorizontalAlignment="Right" TextAlignment="Right" IsReadOnly="True" 
                                     Background="#FFFACD" Foreground="#f44336" BorderThickness="2" BorderBrush="#f44336"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Cash Received:" FontSize="14" FontWeight="Bold"/>
                            <TextBox Text="{Binding ReceiveCash, UpdateSourceTrigger=PropertyChanged}" 
                                     FontSize="14" FontWeight="Bold" Padding="8" Width="180" 
                                     HorizontalAlignment="Right" TextAlignment="Right" BorderThickness="2" BorderBrush="#4CAF50"/>
                        </Grid>

                        <Grid>
                            <TextBlock Text="Balance:" FontSize="14" FontWeight="Bold" Foreground="#2196F3"/>
                            <TextBox Text="{Binding Balance, StringFormat=Rs. {0:N2}, Mode=OneWay}" 
                                     FontSize="16" FontWeight="Bold" Padding="8" Width="180" 
                                     HorizontalAlignment="Right" TextAlignment="Right" IsReadOnly="True" 
                                     Background="#E3F2FD" Foreground="#2196F3" BorderThickness="2" BorderBrush="#2196F3"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
