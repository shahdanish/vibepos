<Window x:Class="POSApp.UI.Views.PharmacySaleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Pharmacy Sale - Master Pharmaceuticals Distributor"
        Height="750" Width="1200"
        WindowStartupLocation="CenterScreen" WindowState="Maximized">
    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBar}" Padding="15">
            <Grid>
                <TextBlock Text="PHARMACY SALE" FontSize="28" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding InvoiceNumber, StringFormat='Invoice #: {0}'}"
                           FontSize="18" FontWeight="Bold" Foreground="Yellow"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top Sections -->
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" MaxHeight="300" Margin="0,0,0,10">
                <StackPanel>

                    <!-- Pharmacy / Doctor / Payment / Date -->
                    <Border Style="{StaticResource CardBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 1: Pharmacy, Doctor, Payment, Date -->
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>

                                <!-- Pharmacy dropdown -->
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock FontWeight="Bold" FontSize="12" Margin="0,0,0,5">
                                        <Run Text="Pharmacy " Foreground="{DynamicResource DangerBrush}"/>
                                        <Run Text="*" Foreground="{DynamicResource DangerBrush}"/>
                                    </TextBlock>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="32"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0"
                                                  x:Name="PharmacyCombo"
                                                  ItemsSource="{Binding FilteredPharmacies}"
                                                  SelectedItem="{Binding SelectedPharmacy}"
                                                  DisplayMemberPath="DisplayLabel"
                                                  IsEditable="True"
                                                  IsTextSearchEnabled="False"
                                                  Text="{Binding PharmacySearchText, UpdateSourceTrigger=PropertyChanged}"
                                                  StaysOpenOnEdit="True"
                                                  FontSize="13" Padding="6"/>
                                        <Button Grid.Column="1" Content="＋" ToolTip="Add new pharmacy"
                                                Command="{Binding AddPharmacyCommand}"
                                                Width="30" Height="30"
                                                FontSize="18" FontWeight="Bold"
                                                Background="#27ae60" Foreground="White"
                                                BorderThickness="0"
                                                Cursor="Hand" Margin="3,0,0,0">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#219a52"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </StackPanel>

                                <!-- Doctor dropdown -->
                                <StackPanel Grid.Column="1" Margin="10,0">
                                    <TextBlock Text="Doctor (optional)" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="32"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0"
                                                  x:Name="DoctorCombo"
                                                  ItemsSource="{Binding FilteredDoctors}"
                                                  SelectedItem="{Binding SelectedDoctor}"
                                                  DisplayMemberPath="DisplayLabel"
                                                  IsEditable="True"
                                                  IsTextSearchEnabled="False"
                                                  Text="{Binding DoctorSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                  StaysOpenOnEdit="True"
                                                  FontSize="13" Padding="6"/>
                                        <Button Grid.Column="1" Content="＋" ToolTip="Add new doctor"
                                                Command="{Binding AddDoctorCommand}"
                                                Width="30" Height="30"
                                                FontSize="18" FontWeight="Bold"
                                                Background="#27ae60" Foreground="White"
                                                BorderThickness="0"
                                                Cursor="Hand" Margin="3,0,0,0">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#219a52"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </StackPanel>

                                <!-- Payment Method -->
                                <StackPanel Grid.Column="2" Margin="10,0">
                                    <TextBlock Text="Payment Method" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                                    <ComboBox ItemsSource="{Binding PaymentTypes}"
                                              SelectedItem="{Binding PaymentType}"
                                              FontSize="13" Padding="6"/>
                                </StackPanel>

                                <!-- Sale Date -->
                                <StackPanel Grid.Column="3" Margin="10,0,0,0">
                                    <TextBlock Text="Sale Date" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                                    <DatePicker SelectedDate="{Binding SaleDate}" FontSize="13" Padding="6"/>
                                </StackPanel>
                            </Grid>

                            <!-- Row 2: Bill Note + checkboxes -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Bill Note (Optional)" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding BillNote, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="13" Padding="6"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0" VerticalAlignment="Bottom" Orientation="Horizontal">
                                    <CheckBox Content="Auto Add" IsChecked="{Binding AutoAddItem}"
                                              FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Bottom" Orientation="Horizontal">
                                    <CheckBox Content="Auto Print" IsChecked="{Binding AutoPrint}"
                                              FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PurpleBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Product Entry -->
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.3*"/>
                                <ColumnDefinition Width="1.3*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Scan Barcode" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="BarcodeBox"
                                         Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="13" Padding="6">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter" Command="{Binding ScanCommand}"/>
                                    </TextBox.InputBindings>
                                </TextBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="Select Product" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding FilteredProducts}"
                                          SelectedItem="{Binding SelectedProduct}"
                                          DisplayMemberPath="ProductName"
                                          IsEditable="True"
                                          IsTextSearchEnabled="False"
                                          Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}"
                                          StaysOpenOnEdit="True"
                                          FontSize="13" Padding="6"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                <TextBlock Text="Price (Rs)" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="13" Padding="6" TextAlignment="Right"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="0,0,10,0">
                                <TextBlock Text="Qty" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="13" Padding="6" TextAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4" Margin="0,0,10,0">
                                <TextBlock Text="Disc %" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding DiscountPercent, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="13" Padding="6" TextAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="5" Margin="0,0,10,0">
                                <TextBlock Text="Stock" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding SelectedProduct.Stock}"
                                         FontSize="13" Padding="6" IsReadOnly="True"
                                         Background="#f0f0f0" TextAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Bottom">
                                <StackPanel Margin="0,0,15,0" VerticalAlignment="Center"
                                            Visibility="{Binding IsLastScannedCostVisible, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Item Cost" FontWeight="Bold" FontSize="10"
                                               Foreground="{DynamicResource WarningBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding LastScannedCost, StringFormat={}{0:N2}}"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="{DynamicResource WarningBrush}" TextAlignment="Center"/>
                                </StackPanel>
                                <Button Content="Add Item" Command="{Binding AddItemCommand}"
                                        Style="{StaticResource SuccessButton}" Padding="15,8"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Items Grid -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Sale Items" Style="{StaticResource SectionTitle}"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding SaleItems}"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              AlternatingRowBackground="#F9F9F9"
                              HeadersVisibility="All" GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product ID" Binding="{Binding ProductId}" IsReadOnly="True" Width="120"/>
                            <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" IsReadOnly="True" Width="*"/>
                            <DataGridTextColumn Header="Unit Price" Width="100" ElementStyle="{StaticResource RightAlignStyle}">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="UnitPrice" StringFormat="N2" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Qty" Width="70" ElementStyle="{StaticResource CenterAlignStyle}">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="Quantity" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Disc %" Width="70" ElementStyle="{StaticResource CenterAlignStyle}">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="DiscountPercent" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Batch No" Binding="{Binding BatchNo}"
                                                IsReadOnly="True" Width="90" ElementStyle="{StaticResource CenterAlignStyle}"/>
                            <DataGridTextColumn Header="Expiry" Width="70" IsReadOnly="True"
                                                Binding="{Binding ExpiryDate, StringFormat=MM/yyyy}"
                                                ElementStyle="{StaticResource CenterAlignStyle}"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=N2}"
                                                IsReadOnly="True" Width="110" ElementStyle="{StaticResource RightAlignStyle}"/>
                            <DataGridTemplateColumn Header="Action" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Del"
                                                Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource DangerButton}"
                                                Padding="6,2" FontSize="11"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Bottom: Actions + Totals -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="350"/>
                </Grid.ColumnDefinitions>

                <!-- Action Buttons -->
                <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,10,0">
                    <WrapPanel VerticalAlignment="Bottom" HorizontalAlignment="Left">
                        <Button Content="NEW SALE" Command="{Binding NewSaleCommand}"
                                Style="{StaticResource InfoButton}" Padding="15,10" Margin="0,0,8,5" MinWidth="110"/>
                        <Button Content="SAVE SALE" Command="{Binding SaveCommand}"
                                Style="{StaticResource SuccessButton}" Padding="15,10" Margin="0,0,8,5" MinWidth="110"/>
                        <Button Content="PRINT" Command="{Binding PrintCommand}"
                                Style="{StaticResource PurpleButton}" Padding="15,10" Margin="0,0,8,5" MinWidth="110"/>
                        <Button Content="CLEAR" Command="{Binding ClearCommand}"
                                Style="{StaticResource WarningButton}" Padding="15,10" Margin="0,0,8,5" MinWidth="110"/>
                        <Button Content="CLOSE" Click="Exit_Click"
                                Style="{StaticResource NeutralButton}" Padding="15,10" Margin="0,0,0,5" MinWidth="110"/>
                    </WrapPanel>
                </Border>

                <!-- Totals Panel -->
                <Border Grid.Column="1" Style="{StaticResource ElevatedCardBorder}" Padding="15">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Discount on Bill:" FontSize="13" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding DiscountOnBill, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="13" Padding="6" Width="120"
                                     HorizontalAlignment="Right" TextAlignment="Right"/>
                        </Grid>

                        <Border BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="0,8,0,0"/>

                        <Grid Margin="0,8,0,8">
                            <TextBlock Text="TOTAL BILL:" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource DangerBrush}"/>
                            <TextBox Text="{Binding TotalBill, StringFormat=Rs. {0:N2}, Mode=OneWay}"
                                     Style="{StaticResource TotalDisplay}" Width="180" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Cash Received:" FontSize="14" FontWeight="Bold"/>
                            <TextBox Text="{Binding ReceiveCash, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="14" FontWeight="Bold" Padding="8" Width="180"
                                     HorizontalAlignment="Right" TextAlignment="Right"
                                     BorderThickness="2" BorderBrush="{DynamicResource SuccessBrush}"/>
                        </Grid>

                        <Grid>
                            <TextBlock Text="Balance:" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource InfoBrush}"/>
                            <TextBox Text="{Binding Balance, StringFormat=Rs. {0:N2}, Mode=OneWay}"
                                     FontSize="16" FontWeight="Bold" Padding="8" Width="180"
                                     HorizontalAlignment="Right" TextAlignment="Right"
                                     IsReadOnly="True" Background="#E3F2FD"
                                     Foreground="{DynamicResource InfoBrush}"
                                     BorderThickness="2" BorderBrush="{DynamicResource InfoBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
