<Window x:Class="POSApp.UI.Views.SalesReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POSApp.UI.Views"
        mc:Ignorable="d"
        Title="Sales Reports - Shah Jee Super Store" Height="850" Width="1400"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBar}" Padding="20">
            <Grid>
                <TextBlock Text="Sales Reports &amp; Analytics" FontSize="28" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center"/>
                <Button Content="Close" Click="Exit_Click" HorizontalAlignment="Right" 
                        Style="{StaticResource PrimaryButton}" Padding="15,8"/>
            </Grid>
        </Border>

        <!-- Quick Report Buttons -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="10,10,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Quick Reports" Style="{StaticResource SectionTitle}" Margin="0,0,0,15"/>

                <WrapPanel Grid.Row="1">
                    <Button Content="TODAY" Command="{Binding ShowTodayCommand}" 
                            Style="{StaticResource SuccessButton}" Padding="20,12" Margin="0,0,10,10" MinWidth="130"
                            FontSize="14" FontWeight="Bold"/>
                    <Button Content="THIS WEEK" Command="{Binding ShowThisWeekCommand}" 
                            Style="{StaticResource InfoButton}" Padding="20,12" Margin="0,0,10,10" MinWidth="130"
                            FontSize="14" FontWeight="Bold"/>
                    <Button Content="THIS MONTH" Command="{Binding ShowThisMonthCommand}" 
                            Style="{StaticResource WarningButton}" Padding="20,12" Margin="0,0,10,10" MinWidth="130"
                            FontSize="14" FontWeight="Bold"/>
                    <Button Content="THIS YEAR" Command="{Binding ShowThisYearCommand}" 
                            Style="{StaticResource PurpleButton}" Padding="20,12" Margin="0,0,10,10" MinWidth="130"
                            FontSize="14" FontWeight="Bold"/>
                    <Button Content="CUSTOM RANGE" Command="{Binding ShowCustomRangeCommand}" 
                            Style="{StaticResource NeutralButton}" Padding="20,12" Margin="0,0,10,10" MinWidth="150"
                            FontSize="14" FontWeight="Bold"/>
                    <Button Content="INVOICE SEARCH" Command="{Binding ShowInvoiceSearchCommand}" 
                            Style="{StaticResource PrimaryButton}" Padding="20,12" Margin="0,0,10,10" MinWidth="170"
                            FontSize="14" FontWeight="Bold"/>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- Sales Data Grid -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding ReportTitle}" FontSize="20" FontWeight="Bold" 
                               Foreground="{DynamicResource BrandPrimaryBrush}" Margin="0,0,0,10"/>

                    <!-- Search Panel (Collapsed by default) -->
                    <StackPanel Grid.Row="1" x:Name="SearchPanel" Visibility="{Binding SearchPanelVisibility}" Margin="0,0,0,15">
                        <!-- Invoice Search -->
                        <Border x:Name="InvoiceSearchPanel" Visibility="{Binding InvoiceSearchVisibility}" 
                                Style="{StaticResource CardBorder}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Invoice Number:" FontSize="14" FontWeight="SemiBold" 
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBox Grid.Column="1" Text="{Binding InvoiceNumber, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="14" Padding="8" Margin="0,0,10,0"/>
                                <Button Grid.Column="2" Content="Search" Command="{Binding SearchInvoiceCommand}" 
                                        Style="{StaticResource SuccessButton}" Padding="15,8" MinWidth="100"/>
                            </Grid>
                        </Border>

                        <!-- Custom Date Range -->
                        <Border x:Name="CustomRangePanel" Visibility="{Binding CustomRangeVisibility}" 
                                Style="{StaticResource CardBorder}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="From:" FontSize="14" FontWeight="SemiBold" 
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <DatePicker Grid.Column="1" SelectedDate="{Binding StartDate}" 
                                            FontSize="14" Padding="8" Margin="0,0,15,0"/>
                                <TextBlock Grid.Column="2" Text="To:" FontSize="14" FontWeight="SemiBold" 
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <DatePicker Grid.Column="3" SelectedDate="{Binding EndDate}" 
                                            FontSize="14" Padding="8" Margin="0,0,15,0"/>
                                <Button Grid.Column="4" Content="Show Report" Command="{Binding SearchDateRangeCommand}" 
                                        Style="{StaticResource InfoButton}" Padding="15,8" MinWidth="130"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Data Grid -->
                    <DataGrid Grid.Row="2" ItemsSource="{Binding Sales}" SelectedItem="{Binding SelectedSale}"
                              AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                              AlternatingRowBackground="#F9F9F9" HeadersVisibility="All" 
                              GridLinesVisibility="Horizontal" BorderThickness="1" BorderBrush="#DDD">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Invoice #" Binding="{Binding InvoiceNumber}" Width="120"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding SaleDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding SaleType}" Width="90"/>
                            <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*" MinWidth="120"/>
                            <DataGridTextColumn Header="Items" Binding="{Binding SaleItems.Count}" Width="60" ElementStyle="{StaticResource CenterAlignStyle}"/>
                            <DataGridTextColumn Header="Discount" Binding="{Binding DiscountOnBill, StringFormat=N2}" Width="90" ElementStyle="{StaticResource RightAlignStyle}"/>
                            <DataGridTextColumn Header="Total (Rs)" Binding="{Binding TotalBill, StringFormat=N2}" Width="110" ElementStyle="{StaticResource RightAlignStyle}"/>
                            <DataGridTemplateColumn Header="Action" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="View" Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                CommandParameter="{Binding}" Style="{StaticResource InfoButton}" 
                                                Padding="8,4" FontSize="11"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Right Panel: Summary & Details -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Summary Statistics -->
                        <TextBlock Text="Summary" Style="{StaticResource SectionTitle}" Margin="0,0,0,15"/>

                        <Border Background="#E8F5E9" Padding="15" Margin="0,0,0,10" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="Total Sales" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding TotalSales}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#E3F2FD" Padding="15" Margin="0,0,0,10" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="Total Revenue" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding TotalRevenue, StringFormat=Rs. {0:N2}}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource InfoBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#FFF3E0" Padding="15" Margin="0,0,0,10" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="Total Cost" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding TotalCost, StringFormat=Rs. {0:N2}}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#F3E5F5" Padding="15" Margin="0,0,0,10" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="Total Profit" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding TotalProfit, StringFormat=Rs. {0:N2}}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PurpleBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#FCE4EC" Padding="15" Margin="0,0,0,15" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="Total Discount Given" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding TotalDiscount, StringFormat=Rs. {0:N2}}" FontSize="20" FontWeight="Bold" Foreground="#E91E63"/>
                            </StackPanel>
                        </Border>

                        <!-- Selected Sale Details -->
                        <Border BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="0,15,0,0" Margin="0,10,0,0" 
                                Visibility="{Binding SelectedSaleVisibility}">
                            <StackPanel>
                                <TextBlock Text="Selected Sale Details" FontSize="16" FontWeight="Bold" 
                                           Foreground="{DynamicResource BrandPrimaryBrush}" Margin="0,0,0,15"/>

                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Invoice:" FontSize="12" Foreground="#666"/>
                                    <TextBlock Text="{Binding SelectedSale.InvoiceNumber}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Customer:" FontSize="12" Foreground="#666"/>
                                    <TextBlock Text="{Binding SelectedSale.CustomerName}" FontSize="14" HorizontalAlignment="Right"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Payment:" FontSize="12" Foreground="#666"/>
                                    <TextBlock Text="{Binding SelectedSale.PaymentType}" FontSize="14" HorizontalAlignment="Right"/>
                                </Grid>

                                <Border Background="{DynamicResource PageBackgroundBrush}" Padding="10" Margin="0,10,0,0" CornerRadius="5">
                                    <StackPanel>
                                        <TextBlock Text="Sale Items:" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <ItemsControl ItemsSource="{Binding SelectedSale.SaleItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="5" Margin="0,0,0,5">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition/>
                                                                <RowDefinition/>
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Grid.Row="0" Text="{Binding ProductName}" FontSize="11" FontWeight="SemiBold"/>
                                                            <StackPanel Grid.Row="1" Orientation="Horizontal">
                                                                <TextBlock Text="{Binding Quantity}" FontSize="10" Foreground="#666"/>
                                                                <TextBlock Text=" × Rs." FontSize="10" Foreground="#666"/>
                                                                <TextBlock Text="{Binding UnitPrice, StringFormat=N2}" FontSize="10" Foreground="#666"/>
                                                                <TextBlock Text=" = Rs." FontSize="10" Foreground="#666" Margin="5,0,0,0"/>
                                                                <TextBlock Text="{Binding Total, StringFormat=N2}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Button Content="Print Invoice" Command="{Binding PrintCommand}" 
                                        Style="{StaticResource SuccessButton}" Padding="12,8" Margin="0,15,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Footer Actions -->
        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Margin="10,0,10,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Print Report" Command="{Binding PrintReportCommand}" 
                        Style="{StaticResource InfoButton}" Padding="20,10" Margin="0,0,10,0" MinWidth="150"
                        FontSize="14" FontWeight="Bold"/>
                <Button Content="Export to Excel" Command="{Binding ExportCommand}" 
                        Style="{StaticResource SuccessButton}" Padding="20,10" Margin="0,0,10,0" MinWidth="150"
                        FontSize="14" FontWeight="Bold"/>
                <Button Content="Refresh" Command="{Binding RefreshCommand}" 
                        Style="{StaticResource WarningButton}" Padding="20,10" MinWidth="120"
                        FontSize="14" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
