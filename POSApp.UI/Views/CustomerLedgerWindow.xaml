<Window x:Class="POSApp.UI.Views.CustomerLedgerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customer Ledger (Khata) - Shah Jee Super Store" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen" WindowState="Maximized">
    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBar}">
            <TextBlock Text="📒 Customer Ledger (Khata)" FontSize="24" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Customer List -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Customers" Style="{StaticResource SectionTitle}"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Customers}"
                              SelectedItem="{Binding SelectedCustomer}"
                              AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="100"/>
                            <DataGridTextColumn Header="Balance (Rs.)" Binding="{Binding CurrentBalance, StringFormat=N2}" Width="100"/>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentBalance, Converter={StaticResource GreaterThanZeroConverter}}" Value="True">
                                        <Setter Property="Background" Value="#FFF5F5"/>
                                        <Setter Property="Foreground" Value="#C53030"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>

                    <Button Grid.Row="2" Content="🔄 Refresh" Command="{Binding RefreshCommand}"
                            Style="{StaticResource InfoButton}" Padding="8,6" Margin="0,10,0,0"/>
                </Grid>
            </Border>

            <!-- Payment History -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Payment History" Style="{StaticResource SectionTitle}"/>
                        <TextBlock FontSize="13" Foreground="Gray">
                            <Run Text="Customer: "/>
                            <Run Text="{Binding SelectedCustomer.Name, FallbackValue='— select a customer —'}" FontWeight="SemiBold"/>
                        </TextBlock>
                        <TextBlock FontSize="14" Margin="0,4,0,0">
                            <Run Text="Outstanding Balance: Rs. " FontWeight="Bold"/>
                            <Run Text="{Binding SelectedCustomer.CurrentBalance, StringFormat=N2, FallbackValue='0.00'}"
                                 FontWeight="Bold" Foreground="#C53030"/>
                        </TextBlock>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Payments}"
                              AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding PaymentDate, StringFormat=dd/MM/yy hh:mm tt}" Width="130"/>
                            <DataGridTextColumn Header="Amount (Rs.)" Binding="{Binding AmountPaid, StringFormat=N2}" Width="100"/>
                            <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Right Panel: Add Customer + Record Payment -->
            <Border Grid.Column="4" Style="{StaticResource CardBorder}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- Add Customer Section -->
                        <TextBlock Text="Add New Customer" Style="{StaticResource SectionTitle}"/>

                        <TextBlock Text="Name *" FontWeight="SemiBold" Margin="0,0,0,4" FontSize="12"/>
                        <TextBox Text="{Binding NewCustomerName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="7" Margin="0,0,0,10" FontSize="13"/>

                        <TextBlock Text="Phone" FontWeight="SemiBold" Margin="0,0,0,4" FontSize="12"/>
                        <TextBox Text="{Binding NewCustomerPhone, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="7" Margin="0,0,0,10" FontSize="13"/>

                        <TextBlock Text="Address" FontWeight="SemiBold" Margin="0,0,0,4" FontSize="12"/>
                        <TextBox Text="{Binding NewCustomerAddress, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="7" Margin="0,0,0,10" FontSize="13"/>

                        <TextBlock Text="Initial Balance (Rs.)" FontWeight="SemiBold" Margin="0,0,0,4" FontSize="12"/>
                        <TextBox Text="{Binding NewCustomerInitialBalance, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="7" Margin="0,0,0,12" FontSize="13" TextAlignment="Right"/>

                        <Button Content="➕ Add Customer" Command="{Binding AddCustomerCommand}"
                                Style="{StaticResource InfoButton}" Padding="10,8" Margin="0,0,0,16"/>

                        <Border BorderBrush="#DDD" BorderThickness="0,1,0,0" Margin="0,0,0,16"/>

                        <!-- Record Payment Section -->
                        <TextBlock Text="Record Payment" Style="{StaticResource SectionTitle}"/>

                        <TextBlock Text="Select Customer" FontWeight="SemiBold" Margin="0,0,0,4" FontSize="12"/>
                        <ComboBox ItemsSource="{Binding Customers}"
                                  SelectedItem="{Binding SelectedCustomer}"
                                  DisplayMemberPath="Name"
                                  IsEditable="True" IsTextSearchEnabled="True"
                                  FontSize="13" Padding="6" Margin="0,0,0,6"/>

                        <!-- Outstanding balance preview -->
                        <TextBlock FontSize="12" Margin="0,0,0,10" Foreground="{DynamicResource DangerBrush}" FontWeight="SemiBold">
                            <Run Text="Outstanding: Rs. "/>
                            <Run Text="{Binding SelectedCustomer.CurrentBalance, StringFormat=N2, FallbackValue='0.00'}"/>
                        </TextBlock>

                        <TextBlock Text="Amount (Rs.) *" FontWeight="SemiBold" Margin="0,0,0,4" FontSize="12"/>
                        <TextBox Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="7" Margin="0,0,0,10" FontSize="13" TextAlignment="Right"/>

                        <TextBlock Text="Note (Optional)" FontWeight="SemiBold" Margin="0,0,0,4" FontSize="12"/>
                        <TextBox Text="{Binding PaymentNote, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="7" Margin="0,0,0,14" FontSize="13"
                                 TextWrapping="Wrap" AcceptsReturn="True" Height="55"/>

                        <Button Content="✅ Record Payment" Command="{Binding AddPaymentCommand}"
                                Style="{StaticResource SuccessButton}" Padding="10,8" Margin="0,0,0,10"/>
                        <Button Content="🖨️ Reprint Last Receipt" Command="{Binding PrintReceiptCommand}"
                                Style="{StaticResource InfoButton}" Padding="10,8" Margin="0,0,0,10"/>
                        <Button Content="Close" Click="Close_Click"
                                Style="{StaticResource NeutralButton}" Padding="10,8"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
