<Window x:Class="POSApp.UI.Views.RoleManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Role Management"
        Height="580" Width="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Icon="/app-icon.png">
    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBar}">
            <TextBlock Text="Role Management" FontSize="24" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{DynamicResource BrandAccentBrush}" Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="＋  Add Role"
                        Command="{Binding AddCommand}"
                        Style="{StaticResource SuccessButton}"
                        Padding="14,6" FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- Roles DataGrid -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="16,12,16,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <DataGrid ItemsSource="{Binding Roles}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          RowBackground="White"
                          AlternatingRowBackground="#F9F9F9"
                          CanUserSortColumns="True"
                          BorderThickness="0">
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Role Name" Binding="{Binding Name}" Width="160" MinWidth="120"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>

                        <!-- Permission count -->
                        <DataGridTemplateColumn Header="Permissions" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#E3F2FD" CornerRadius="4" Padding="8,2" HorizontalAlignment="Center">
                                        <TextBlock Foreground="#1565C0" FontWeight="SemiBold" FontSize="12">
                                            <Run Text="{Binding RolePermissions.Count, Mode=OneWay}"/>
                                            <Run Text=" perms"/>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- System Role badge -->
                        <DataGridTemplateColumn Header="Type" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#FF9800"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSystemRole}" Value="False">
                                                        <Setter Property="Background" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="White">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="System"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSystemRole}" Value="False">
                                                            <Setter Property="Text" Value="Custom"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Action buttons -->
                        <DataGridTemplateColumn Header="Actions" Width="200" CanUserSort="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4,2">
                                        <Button Content="✏ Edit Permissions"
                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource InfoButton}"
                                                Padding="8,4" FontSize="12" Margin="0,0,4,0"/>

                                        <Button Content="🗑 Delete"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Padding="8,4" FontSize="12">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSystemRole}" Value="True">
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                            <Setter Property="Opacity" Value="0.4"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,8">
            <Button Content="🔄 Refresh" Command="{Binding RefreshCommand}"
                    Style="{StaticResource InfoButton}" Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="✕ Close" Click="Close_Click"
                    Style="{StaticResource NeutralButton}" Padding="12,6"/>
        </StackPanel>
    </Grid>
</Window>
