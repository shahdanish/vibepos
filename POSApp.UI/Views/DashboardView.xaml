<UserControl x:Class="POSApp.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main Content: Top Sellers + Low Stock -->
        <Grid Grid.Row="0" Margin="20,15,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Top Selling Products -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="🏆 Top Sellers (Last 30 Days)" Style="{StaticResource SectionTitle}"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding TopSellingProducts}"
                              AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Qty Sold" Binding="{Binding TotalQuantity}" Width="80"/>
                            <DataGridTextColumn Header="Revenue" Binding="{Binding TotalRevenue, StringFormat=N0}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Low Stock Products -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header row with title + demand order button -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="⚠️ Low Stock Alert" Style="{StaticResource SectionTitle}" Margin="0"/>
                        <Button Content="📋 Demand Order"
                                Command="{Binding OpenDemandOrderCommand}"
                                Style="{StaticResource WarningButton}"
                                Padding="10,6" FontSize="12"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                ToolTip="Open demand order form to restock low-stock items"/>
                    </Grid>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding LowStockProducts}"
                              AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                              AlternatingRowBackground="#FFF5F5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="110"/>
                            <DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="65"
                                                ElementStyle="{StaticResource CenterAlignStyle}"/>
                            <DataGridTextColumn Header="Alert At" Binding="{Binding Threshold}" Width="65"
                                                ElementStyle="{StaticResource CenterAlignStyle}"/>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#FFF5F5"/>
                                <Setter Property="Foreground" Value="#C53030"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOutOfStock}" Value="True">
                                        <Setter Property="Background" Value="#FED7D7"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- Action buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="20,10,20,12">
            <Button Content="☁ Force Sync to Firebase" Command="{Binding ForceSyncCommand}"
                    Style="{StaticResource WarningButton}" Padding="14,8" Margin="0,0,10,0"/>
            <Button Content="🔄 Refresh" Command="{Binding RefreshCommand}"
                    Style="{StaticResource InfoButton}" Padding="14,8"/>
        </StackPanel>
    </Grid>
</UserControl>
