<Window x:Class="POSApp.UI.Views.SaleReturnWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POSApp.UI.Views"
        mc:Ignorable="d"
        Title="Sale Return - Shah Jee Super Store" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen" WindowState="Maximized">
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#f44336" Padding="15">
            <Grid>
                <TextBlock Text="🔄 SALE RETURN" FontSize="28" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ReturnInvoiceNumber, StringFormat='Return Invoice: {0}'}" 
                           FontSize="18" FontWeight="Bold" Foreground="Yellow" 
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Main Content Grid -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Search & Date -->
                <RowDefinition Height="*"/>    <!-- Items Grid (Stretches) -->
                <RowDefinition Height="Auto"/> <!-- Actions -->
            </Grid.RowDefinitions>

            <!-- Search Section -->
            <Border Grid.Row="0" Background="White" Padding="15" Margin="0,0,0,10" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Search Original Invoice" FontSize="16" FontWeight="Bold" 
                               Foreground="#f44336" Margin="0,0,0,10"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Invoice #:" FontSize="13" FontWeight="SemiBold" 
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Column="1" Text="{Binding SearchInvoiceNumber, UpdateSourceTrigger=PropertyChanged}" 
                                 FontSize="13" Padding="8" Margin="0,0,10,0"/>
                        <Button Grid.Column="2" Content="🔍 Search" Command="{Binding SearchCommand}" 
                                Padding="15,8" Background="#2196F3" Foreground="White" FontSize="13" 
                                FontWeight="Bold" MinWidth="110" BorderThickness="0"/>

                        <TextBlock Grid.Column="3" Text="Return Date:" FontSize="13" FontWeight="SemiBold" 
                                   VerticalAlignment="Center" Margin="15,0,10,0"/>
                        <DatePicker Grid.Column="4" SelectedDate="{Binding ReturnDate}" 
                                    FontSize="13" Padding="8" Width="130"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Return Items Section (Stretches) -->
            <Border Grid.Row="1" Background="White" Padding="15" Margin="0,0,0,10" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Items to Return" FontSize="16" FontWeight="Bold" 
                               Margin="0,0,0,10"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding ReturnItems}" AutoGenerateColumns="False" 
                              CanUserAddRows="False" AlternatingRowBackground="#F9F9F9" 
                              HeadersVisibility="All" GridLinesVisibility="Horizontal" BorderThickness="1" BorderBrush="#DDD"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product ID" Binding="{Binding ProductId}" Width="120" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Orig Qty" Binding="{Binding OriginalQuantity}" Width="90" 
                                                ElementStyle="{StaticResource CenterAlignStyle}" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Ret Qty" Binding="{Binding ReturnQuantity, UpdateSourceTrigger=PropertyChanged}" 
                                                Width="90" ElementStyle="{StaticResource CenterAlignStyle}"/>
                            <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat=N2}" Width="100" 
                                                ElementStyle="{StaticResource RightAlignStyle}" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding Total, StringFormat=N2}" Width="110" 
                                                ElementStyle="{StaticResource RightAlignStyle}" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Return Reason" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                            <TextBox Text="{Binding ReturnReason, UpdateSourceTrigger=PropertyChanged}" 
                                     FontSize="13" Padding="8" TextWrapping="Wrap" MaxLength="200"/>
                        </StackPanel>

                        <Border Grid.Column="1" Background="#FFEBEE" Padding="15" Margin="15,0,0,0" 
                                CornerRadius="5" BorderBrush="#f44336" BorderThickness="2">
                            <StackPanel>
                                <TextBlock Text="TOTAL REFUND" FontSize="11" Foreground="#666" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding TotalReturnAmount, StringFormat=Rs. {0:N2}}" 
                                           FontSize="20" FontWeight="Bold" Foreground="#f44336"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Action Buttons -->
            <Border Grid.Row="2" Background="White" Padding="12" CornerRadius="5">
                <WrapPanel HorizontalAlignment="Center">
                    <Button Content="✅ PROCESS RETURN" Command="{Binding ProcessReturnCommand}" 
                            Padding="20,10" Margin="0,0,10,5" Background="#4CAF50" Foreground="White" 
                            FontSize="13" FontWeight="Bold" MinWidth="150" BorderThickness="0"/>
                    <Button Content="🖨️ PRINT" Command="{Binding PrintReturnCommand}" 
                            Padding="20,10" Margin="0,0,10,5" Background="#9C27B0" Foreground="White" 
                            FontSize="13" FontWeight="Bold" MinWidth="140" BorderThickness="0"/>
                    <Button Content="❌ CANCEL" Command="{Binding CancelCommand}" 
                            Padding="20,10" Margin="0,0,10,5" Background="#FF9800" Foreground="White" 
                            FontSize="13" FontWeight="Bold" MinWidth="120" BorderThickness="0"/>
                    <Button Content="CLOSE" Click="Close_Click" 
                            Padding="20,10" Margin="0,0,0,5" Background="#9E9E9E" Foreground="White" 
                            FontSize="13" FontWeight="Bold" MinWidth="110" BorderThickness="0"/>
                </WrapPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
