<Window x:Class="POSApp.UI.Views.SaleReturnWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POSApp.UI.Views"
        mc:Ignorable="d"
        Title="Sale Return - Shah Jee Super Store" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#f44336" Padding="20">
            <Grid>
                <TextBlock Text="🔄 SALE RETURN" FontSize="32" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ReturnInvoiceNumber, StringFormat='Return Invoice: {0}'}" 
                           FontSize="20" FontWeight="Bold" Foreground="Yellow" 
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Search Section -->
            <Border Grid.Row="0" Background="White" Padding="20" Margin="0,0,0,15" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Search Original Invoice" FontSize="18" FontWeight="Bold" 
                               Foreground="#f44336" Margin="0,0,0,15"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Invoice Number:" FontSize="14" FontWeight="SemiBold" 
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Column="1" Text="{Binding SearchInvoiceNumber, UpdateSourceTrigger=PropertyChanged}" 
                                 FontSize="14" Padding="10" Margin="0,0,15,0"/>
                        <Button Grid.Column="2" Content="🔍 Search" Command="{Binding SearchCommand}" 
                                Padding="20,10" Background="#2196F3" Foreground="White" FontSize="14" 
                                FontWeight="Bold" MinWidth="120" BorderThickness="0"/>

                        <TextBlock Grid.Column="3" Text="Return Date:" FontSize="14" FontWeight="SemiBold" 
                                   VerticalAlignment="Center" Margin="20,0,10,0"/>
                        <DatePicker Grid.Column="4" SelectedDate="{Binding ReturnDate}" 
                                    FontSize="14" Padding="10" Width="150"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Return Items Section -->
            <Border Grid.Row="1" Background="White" Padding="20" Margin="0,0,0,15" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Items to Return" FontSize="18" FontWeight="Bold" 
                               Margin="0,0,0,15"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding ReturnItems}" AutoGenerateColumns="False" 
                              CanUserAddRows="False" AlternatingRowBackground="#F9F9F9" 
                              HeadersVisibility="All" GridLinesVisibility="Horizontal" BorderThickness="1" BorderBrush="#DDD">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product ID" Binding="{Binding ProductId}" Width="120" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Original Qty" Binding="{Binding OriginalQuantity}" Width="100" 
                                                ElementStyle="{StaticResource CenterAlignStyle}" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Return Qty" Binding="{Binding ReturnQuantity, UpdateSourceTrigger=PropertyChanged}" 
                                                Width="100" ElementStyle="{StaticResource CenterAlignStyle}"/>
                            <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat=N2}" Width="100" 
                                                ElementStyle="{StaticResource RightAlignStyle}" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Return Amount" Binding="{Binding Total, StringFormat=N2}" Width="120" 
                                                ElementStyle="{StaticResource RightAlignStyle}" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="2" Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Return Reason (Required)" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding ReturnReason, UpdateSourceTrigger=PropertyChanged}" 
                                     FontSize="14" Padding="10" TextWrapping="Wrap" MaxLength="200"/>
                        </StackPanel>

                        <Border Grid.Column="1" Background="#FFEBEE" Padding="20" Margin="20,0,0,0" 
                                CornerRadius="5" BorderBrush="#f44336" BorderThickness="2">
                            <StackPanel>
                                <TextBlock Text="TOTAL REFUND" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding TotalReturnAmount, StringFormat=Rs. {0:N2}}" 
                                           FontSize="24" FontWeight="Bold" Foreground="#f44336"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Action Buttons -->
            <Border Grid.Row="2" Background="White" Padding="15" CornerRadius="5">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="✅ PROCESS RETURN" Command="{Binding ProcessReturnCommand}" 
                            Padding="25,12" Margin="0,0,15,0" Background="#4CAF50" Foreground="White" 
                            FontSize="14" FontWeight="Bold" MinWidth="180" BorderThickness="0"/>
                    <Button Content="🖨️ PRINT RECEIPT" Command="{Binding PrintReturnCommand}" 
                            Padding="25,12" Margin="0,0,15,0" Background="#9C27B0" Foreground="White" 
                            FontSize="14" FontWeight="Bold" MinWidth="180" BorderThickness="0"/>
                    <Button Content="❌ CANCEL" Command="{Binding CancelCommand}" 
                            Padding="25,12" Margin="0,0,15,0" Background="#FF9800" Foreground="White" 
                            FontSize="14" FontWeight="Bold" MinWidth="150" BorderThickness="0"/>
                    <Button Content="CLOSE" Click="Close_Click" 
                            Padding="25,12" Background="#9E9E9E" Foreground="White" 
                            FontSize="14" FontWeight="Bold" MinWidth="120" BorderThickness="0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
