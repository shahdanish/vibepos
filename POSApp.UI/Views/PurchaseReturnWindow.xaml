<Window x:Class="POSApp.UI.Views.PurchaseReturnWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Purchase Return - Shah Jee Super Store" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen" WindowState="Maximized">
    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource WarningBrush}" Padding="15">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.25" Direction="270" Color="Black"/>
            </Border.Effect>
            <Grid>
                <TextBlock Text="PURCHASE RETURN" FontSize="28" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ReturnNumber, StringFormat='Return #: {0}'}"
                           FontSize="18" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Search -->
            <Border Grid.Row="0" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Search Original Purchase" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource WarningBrush}" Margin="0,0,0,10"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Purchase #:" FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Column="1" Text="{Binding SearchPurchaseNumber, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" Padding="8" Margin="0,0,10,0">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="2" Content="Search" Command="{Binding SearchCommand}"
                                Style="{StaticResource InfoButton}" Padding="15,8" MinWidth="110"/>

                        <TextBlock Grid.Column="3" Text="Return Date:" FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="15,0,10,0"/>
                        <DatePicker Grid.Column="4" SelectedDate="{Binding ReturnDate}"
                                    FontSize="13" Padding="8" Width="130"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Items to Return -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Items to Return" Style="{StaticResource SectionTitle}"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding ReturnItems}" AutoGenerateColumns="False"
                              CanUserAddRows="False" AlternatingRowBackground="#F9F9F9"
                              HeadersVisibility="All" GridLinesVisibility="Horizontal" BorderThickness="1" BorderBrush="#DDD"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product ID" Binding="{Binding ProductId}" Width="110" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Orig Qty" Binding="{Binding OriginalQuantity}" Width="80"
                                                ElementStyle="{StaticResource CenterAlignStyle}" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Return Qty" Binding="{Binding ReturnQuantity, UpdateSourceTrigger=PropertyChanged}"
                                                Width="90" ElementStyle="{StaticResource CenterAlignStyle}"/>
                            <DataGridTextColumn Header="Unit Cost" Binding="{Binding UnitCost, StringFormat=N2}" Width="100"
                                                ElementStyle="{StaticResource RightAlignStyle}" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding Total, StringFormat=N2}" Width="110"
                                                ElementStyle="{StaticResource RightAlignStyle}" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Return Reason (Optional)" FontWeight="Bold" Margin="0,0,0,5" FontSize="12"/>
                            <TextBox Text="{Binding ReturnReason, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="13" Padding="8" TextWrapping="Wrap" MaxLength="200"/>
                        </StackPanel>

                        <Border Grid.Column="1" Background="#FFF3E0" Padding="15" Margin="15,0,0,0"
                                CornerRadius="8" BorderBrush="{DynamicResource WarningBrush}" BorderThickness="2">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.12" Direction="270" Color="Black"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="TOTAL RETURN VALUE" FontSize="11" Foreground="#666" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding TotalReturnAmount, StringFormat=Rs. {0:N2}}"
                                           FontSize="22" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Actions -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                <WrapPanel HorizontalAlignment="Center">
                    <Button Content="PROCESS RETURN" Command="{Binding ProcessReturnCommand}"
                            Style="{StaticResource SuccessButton}" Padding="20,10" Margin="0,0,10,5" MinWidth="160"/>
                    <Button Content="CANCEL" Command="{Binding CancelCommand}"
                            Style="{StaticResource WarningButton}" Padding="20,10" Margin="0,0,10,5" MinWidth="120"/>
                    <Button Content="CLOSE" Click="Close_Click"
                            Style="{StaticResource NeutralButton}" Padding="20,10" Margin="0,0,0,5" MinWidth="110"/>
                </WrapPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
